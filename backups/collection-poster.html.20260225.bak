<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>清單封面產生器 - MBTI × 桌遊配對</title>
    <link rel="stylesheet" href="css/styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
    <style>
        * { box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; }

        .page-header {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
            color: white;
            padding: 2.5rem 2rem;
            text-align: center;
            position: relative;
        }
        .page-header h1 { font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 900; margin: 0 0 0.4rem; }
        .page-header p  { font-size: 1rem; opacity: 0.75; margin: 0; }
        .back-link {
            position: absolute; top: 1.2rem; left: 1.5rem;
            color: rgba(255,255,255,0.65); text-decoration: none; font-size: 0.9rem;
            transition: color 0.2s;
        }
        .back-link:hover { color: white; }

        .workspace {
            display: grid;
            grid-template-columns: 340px 1fr;
            gap: 1.5rem;
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 1.5rem;
        }
        @media (max-width: 900px) {
            .workspace { grid-template-columns: 1fr; }
        }

        /* ── 設定面板 ── */
        .control-panel {
            display: flex; flex-direction: column; gap: 1.25rem;
        }
        .ctrl-card {
            background: var(--card-bg);
            border-radius: 1rem;
            padding: 1.25rem;
            box-shadow: var(--shadow-md);
        }
        .ctrl-card h3 {
            margin: 0 0 1rem;
            font-size: 0.9rem; font-weight: 700;
            color: var(--text-color); text-transform: uppercase; letter-spacing: 0.5px;
        }

        .form-row { margin-bottom: 0.85rem; }
        .form-row label {
            display: block; font-size: 0.8rem; font-weight: 600;
            color: var(--text-light); margin-bottom: 0.35rem;
        }
        .form-row input[type=text],
        .form-row input[type=number],
        .form-row select,
        .form-row textarea {
            width: 100%; padding: 0.5rem 0.75rem;
            border: 1.5px solid var(--border-color);
            border-radius: 0.6rem; background: var(--bg-color);
            color: var(--text-color); font-size: 0.88rem;
            font-family: inherit; transition: border-color 0.2s;
        }
        .form-row input:focus,
        .form-row select:focus,
        .form-row textarea:focus {
            border-color: var(--primary-color); outline: none;
        }
        .form-row textarea { resize: vertical; min-height: 60px; }

        .range-row {
            display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.85rem;
        }
        .range-row label { font-size: 0.8rem; font-weight: 600; color: var(--text-light); white-space: nowrap; min-width: 80px; }
        .range-row input[type=range] { flex: 1; accent-color: var(--primary-color); }
        .range-row .val { font-size: 0.85rem; font-weight: 700; color: var(--primary-color); min-width: 32px; text-align: right; }

        .chip-row { display: flex; flex-wrap: wrap; gap: 0.4rem; }
        .chip {
            padding: 0.28rem 0.65rem;
            border-radius: 1.5rem;
            border: 1.5px solid var(--border-color);
            background: transparent; font-size: 0.8rem;
            font-weight: 500; color: var(--text-light);
            cursor: pointer; transition: all 0.15s; user-select: none;
        }
        .chip:hover { border-color: var(--primary-color); color: var(--primary-color); }
        .chip.active { background: var(--primary-color); border-color: var(--primary-color); color: white; }

        .color-row { display: flex; gap: 0.5rem; flex-wrap: wrap; }
        .color-swatch {
            width: 28px; height: 28px; border-radius: 0.4rem;
            cursor: pointer; border: 2px solid transparent;
            transition: all 0.15s;
        }
        .color-swatch.active { border-color: var(--primary-color); transform: scale(1.2); }
        .color-swatch.custom { background: conic-gradient(red,orange,yellow,green,blue,violet,red); }

        /* Export Buttons */
        .export-btn {
            width: 100%; padding: 0.85rem;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white; border: none; border-radius: 0.75rem;
            font-size: 0.95rem; font-weight: 700; cursor: pointer;
            transition: all 0.2s; box-shadow: 0 3px 12px rgba(102,126,234,0.35);
            display: flex; align-items: center; justify-content: center; gap: 0.5rem;
            margin-bottom: 0.5rem;
        }
        .export-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(102,126,234,0.45); }
        .export-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

        /* ── 預覽面板 ── */
        .preview-panel {
            position: sticky; top: 1.5rem;
        }
        .preview-wrap {
            background: #111;
            border-radius: 1.25rem;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.4);
        }
        .preview-label {
            text-align: center; padding: 0.6rem;
            font-size: 0.8rem; color: #888; background: #111;
        }

        /* ── POSTER DOM（html2canvas 轉換目標）── */
        #poster-root {
            position: relative;
            overflow: hidden;
            user-select: none;
        }
        .poster-bg {
            position: absolute; inset: 0;
            z-index: 0;
        }
        .poster-content {
            position: relative; z-index: 1;
            padding: 24px;
            display: flex; flex-direction: column;
        }
        .poster-header {
            margin-bottom: 16px;
        }
        .poster-title {
            font-weight: 900; line-height: 1.15;
            word-break: break-word;
        }
        .poster-subtitle {
            line-height: 1.4;
            margin-top: 6px;
            word-break: break-word;
            opacity: 0.8;
        }
        .poster-grid {
            display: grid;
            flex: 1;
        }
        .poster-cell {
            overflow: hidden;
            position: relative;
        }
        .poster-cell img {
            width: 100%; height: 100%; object-fit: cover;
            display: block;
        }
        .poster-cell .cell-blur {
            width: 100%; height: 100%;
            display: flex; align-items: center; justify-content: center;
            font-size: 2rem; font-weight: 900;
            color: rgba(255,255,255,0.5);
        }
        .poster-cell .cell-name {
            position: absolute; bottom: 0; left: 0; right: 0;
            font-size: 11px; padding: 4px 6px;
            background: rgba(0,0,0,0.55);
            color: white; text-align: center;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .poster-footer {
            margin-top: 12px;
            font-size: 11px; opacity: 0.55;
            text-align: right;
        }

        /* Loading */
        .loading-overlay {
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.65);
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            z-index: 9999; backdrop-filter: blur(4px);
        }
        .loading-spinner {
            width: 48px; height: 48px;
            border: 4px solid rgba(255,255,255,0.2);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .loading-text { color: white; margin-top: 1rem; font-weight: 600; }

        /* collection selector */
        .collection-item {
            display: flex; align-items: center; gap: 0.75rem;
            padding: 0.6rem 0.75rem;
            border-radius: 0.6rem; cursor: pointer;
            transition: background 0.15s; border: 1.5px solid transparent;
        }
        .collection-item:hover { background: var(--bg-light); }
        .collection-item.selected { border-color: var(--primary-color); background: rgba(102,126,234,0.07); }
        .collection-icon { font-size: 1.5rem; }
        .collection-info { flex: 1; min-width: 0; }
        .collection-title { font-weight: 600; font-size: 0.88rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .collection-count { font-size: 0.78rem; color: var(--text-light); }
    </style>
</head>
<body>
    <div class="page-header">
        <a href="my-collections.html" class="back-link">← 返回我的清單</a>
        <div style="font-size:2.5rem; margin-bottom:0.4rem;">🖼️</div>
        <h1>清單封面產生器</h1>
        <p>將你的桌遊清單製作成精美海報，一鍵下載分享！</p>
    </div>

    <div class="workspace">
        <!-- ── 左側設定 ── -->
        <div class="control-panel">

            <!-- 選擇清單 -->
            <div class="ctrl-card">
                <h3>📚 選擇清單</h3>
                <div id="collection-list">
                    <div style="text-align:center;padding:1.5rem;color:var(--text-light);font-size:0.88rem;">
                        載入中...
                    </div>
                </div>
                <div class="form-row" style="margin-top:0.75rem;">
                    <label>或直接輸入遊戲（每行一款）</label>
                    <textarea id="manual-games" placeholder="璀璨寶石&#10;卡卡頌&#10;農家樂" rows="4"
                        oninput="scheduleUpdate()"></textarea>
                </div>
            </div>

            <!-- 文字設定 -->
            <div class="ctrl-card">
                <h3>✏️ 標題文字</h3>
                <div class="form-row">
                    <label>清單標題</label>
                    <input type="text" id="poster-title" value="我的最愛桌遊" oninput="scheduleUpdate()">
                </div>
                <div class="form-row">
                    <label>副標題（可選）</label>
                    <input type="text" id="poster-subtitle" placeholder="精選 10 款最愛遊戲" oninput="scheduleUpdate()">
                </div>
                <div class="form-row">
                    <label>標題字色</label>
                    <div class="color-row" id="title-color-row">
                        <div class="color-swatch active" data-color="#ffffff" style="background:#fff;" title="白"></div>
                        <div class="color-swatch" data-color="#f8fafc" style="background:#f8fafc; border:1px solid #ccc;" title="淡白"></div>
                        <div class="color-swatch" data-color="#0f172a" style="background:#0f172a;" title="黑"></div>
                        <div class="color-swatch" data-color="#fbbf24" style="background:#fbbf24;" title="金"></div>
                        <div class="color-swatch" data-color="#60a5fa" style="background:#60a5fa;" title="藍"></div>
                        <div class="color-swatch" data-color="#a78bfa" style="background:#a78bfa;" title="紫"></div>
                        <div class="color-swatch" data-color="#34d399" style="background:#34d399;" title="綠"></div>
                        <div class="color-swatch" data-color="#fb7185" style="background:#fb7185;" title="粉"></div>
                        <input type="color" id="custom-title-color" value="#ffffff"
                            style="width:28px;height:28px;border:none;padding:0;cursor:pointer;border-radius:0.4rem;"
                            title="自訂顏色" oninput="setTitleColor(this.value)">
                    </div>
                </div>
            </div>

            <!-- 佈局設定 -->
            <div class="ctrl-card">
                <h3>🎨 佈局設定</h3>
                <div class="form-row">
                    <label>比例</label>
                    <div class="chip-row" id="ratio-chips">
                        <div class="chip active" data-w="1080" data-h="1080">1:1</div>
                        <div class="chip" data-w="1080" data-h="1350">4:5</div>
                        <div class="chip" data-w="1080" data-h="1920">9:16</div>
                        <div class="chip" data-w="1920" data-h="1080">16:9</div>
                        <div class="chip" data-w="800"  data-h="1200">2:3</div>
                    </div>
                </div>
                <div class="range-row">
                    <label>每行幾款</label>
                    <input type="range" id="cols" min="2" max="6" value="3" step="1" oninput="document.getElementById('cols-val').textContent=this.value; scheduleUpdate()">
                    <span class="val" id="cols-val">3</span>
                </div>
                <div class="range-row">
                    <label>格子間距</label>
                    <input type="range" id="gap" min="0" max="16" value="4" step="2" oninput="document.getElementById('gap-val').textContent=this.value+'px'; scheduleUpdate()">
                    <span class="val" id="gap-val">4px</span>
                </div>
                <div class="range-row">
                    <label>圓角</label>
                    <input type="range" id="radius" min="0" max="20" value="6" step="2" oninput="document.getElementById('radius-val').textContent=this.value+'px'; scheduleUpdate()">
                    <span class="val" id="radius-val">6px</span>
                </div>
                <div class="form-row">
                    <label>無封面時的顯示方式</label>
                    <div class="chip-row" id="fallback-chips">
                        <div class="chip active" data-fallback="blur">模糊色塊</div>
                        <div class="chip" data-fallback="dark">深色</div>
                        <div class="chip" data-fallback="light">淺色</div>
                        <div class="chip" data-fallback="bw">黑白</div>
                        <div class="chip" data-fallback="name">只顯示名稱</div>
                    </div>
                </div>
                <div class="form-row">
                    <label>顯示遊戲名稱</label>
                    <div class="chip-row" id="showname-chips">
                        <div class="chip active" data-showname="hover">滑鼠懸停</div>
                        <div class="chip" data-showname="always">一直顯示</div>
                        <div class="chip" data-showname="none">不顯示</div>
                    </div>
                </div>
            </div>

            <!-- 背景設定 -->
            <div class="ctrl-card">
                <h3>🌈 背景</h3>
                <div class="form-row">
                    <label>背景類型</label>
                    <div class="chip-row" id="bg-type-chips">
                        <div class="chip active" data-bg="gradient-dark">深色漸層</div>
                        <div class="chip" data-bg="gradient-light">淺色漸層</div>
                        <div class="chip" data-bg="solid">純色</div>
                        <div class="chip" data-bg="blur-mosaic">模糊馬賽克</div>
                    </div>
                </div>
                <div id="solid-color-row" style="display:none;">
                    <div class="form-row">
                        <label>背景色</label>
                        <input type="color" id="bg-solid-color" value="#1a1a2e" oninput="scheduleUpdate()">
                    </div>
                </div>
            </div>

            <!-- 匯出 -->
            <div class="ctrl-card">
                <h3>💾 匯出</h3>
                <div class="form-row">
                    <label>解析度</label>
                    <div class="chip-row" id="scale-chips">
                        <div class="chip active" data-scale="1">標準 (1x)</div>
                        <div class="chip" data-scale="2">高清 (2x)</div>
                        <div class="chip" data-scale="3">超清 (3x)</div>
                    </div>
                </div>
                <button class="export-btn" id="download-btn" onclick="downloadPoster()">
                    <span>⬇️</span> 下載 PNG 圖片
                </button>
                <button class="export-btn" onclick="copyPoster()" style="background:linear-gradient(135deg,#10b981,#059669);">
                    <span>📋</span> 複製到剪貼簿
                </button>
                <div id="export-status" style="text-align:center; font-size:0.82rem; color:var(--text-light); margin-top:0.4rem;"></div>
            </div>

        </div>

        <!-- ── 右側預覽 ── -->
        <div class="preview-panel">
            <div class="preview-wrap">
                <div id="poster-container">
                    <!-- poster-root 會由 JS 插入 -->
                </div>
                <div class="preview-label" id="preview-label">預覽（縮放至視窗大小）</div>
            </div>
        </div>
    </div>

    <!-- Loading -->
    <div class="loading-overlay" id="loading-overlay" style="display:none;">
        <div class="loading-spinner"></div>
        <div class="loading-text" id="loading-text">生成中...</div>
    </div>

    <script src="js/app.js"></script>
    <script src="js/game-names.js"></script>
    <script>
    // ── 全域狀態 ──
    let currentUser   = null;
    let gameDatabase  = [];
    let collections   = [];
    let selectedCollection = null;
    let currentGames  = [];   // [{name, imageUrl}]
    let preloadedImages = {}; // name → objectURL (via Jina proxy)
    let updateTimer = null;

    // ── 設定狀態 ──
    let cfg = {
        w: 1080, h: 1080,
        cols: 3, gap: 4, radius: 6,
        fallback: 'blur',   // blur | dark | light | bw | name
        showname: 'hover',  // hover | always | none
        bgType: 'gradient-dark',
        bgColor: '#1a1a2e',
        titleColor: '#ffffff',
        title: '我的最愛桌遊',
        subtitle: '',
        scale: 1,
    };

    // ── 初始化 ──
    document.addEventListener('DOMContentLoaded', async () => {
        try { currentUser = JSON.parse(localStorage.getItem('currentUser') || 'null'); } catch(e) {}

        await Promise.all([loadGameDatabase(), loadCollections()]);
        setupControls();
        scheduleUpdate();
    });

    async function loadGameDatabase() {
        try {
            const r = await fetch('tables/game_database?limit=2000');
            if (r.ok) { const d = await r.json(); gameDatabase = d.data || []; }
        } catch(e) {}
    }

    async function loadCollections() {
        if (!currentUser) {
            document.getElementById('collection-list').innerHTML =
                '<p style="font-size:0.82rem;color:var(--text-light);">登入後可載入你的清單</p>';
            return;
        }
        try {
            const r = await fetch('tables/user_collections?limit=500');
            if (r.ok) {
                const d = await r.json();
                collections = (d.data || []).filter(c => c.created_by === currentUser.id);
            }
        } catch(e) {}

        const listEl = document.getElementById('collection-list');
        if (collections.length === 0) {
            listEl.innerHTML = '<p style="font-size:0.82rem;color:var(--text-light);">你還沒有建立任何清單</p>';
            return;
        }
        listEl.innerHTML = collections.map((c, i) => `
            <div class="collection-item" id="col-item-${i}" onclick="selectCollection(${i})">
                <span class="collection-icon">📋</span>
                <div class="collection-info">
                    <div class="collection-title">${c.title || '未命名清單'}</div>
                    <div class="collection-count">${(c.games || []).length} 款遊戲</div>
                </div>
            </div>`).join('');
    }

    function selectCollection(idx) {
        document.querySelectorAll('.collection-item').forEach(el => el.classList.remove('selected'));
        document.getElementById(`col-item-${idx}`)?.classList.add('selected');
        selectedCollection = collections[idx];
        const c = selectedCollection;
        // 自動填入標題
        document.getElementById('poster-title').value = c.title || '我的桌遊清單';
        document.getElementById('poster-subtitle').value = c.description || '';
        document.getElementById('manual-games').value = '';
        cfg.title    = c.title || '我的桌遊清單';
        cfg.subtitle = c.description || '';
        scheduleUpdate();
    }

    // ── 控制項設定 ──
    function setupControls() {
        // 單選 chip groups
        [
            ['ratio-chips', (el) => { cfg.w = +el.dataset.w; cfg.h = +el.dataset.h; }],
            ['fallback-chips', (el) => { cfg.fallback = el.dataset.fallback; }],
            ['showname-chips', (el) => { cfg.showname = el.dataset.showname; }],
            ['bg-type-chips', (el) => {
                cfg.bgType = el.dataset.bg;
                document.getElementById('solid-color-row').style.display = (cfg.bgType === 'solid') ? 'block' : 'none';
            }],
            ['scale-chips', (el) => { cfg.scale = +el.dataset.scale; }],
        ].forEach(([id, fn]) => {
            document.getElementById(id).querySelectorAll('.chip').forEach(chip => {
                chip.addEventListener('click', () => {
                    document.getElementById(id).querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
                    chip.classList.add('active');
                    fn(chip);
                    scheduleUpdate();
                });
            });
        });

        // Title color swatches
        document.getElementById('title-color-row').querySelectorAll('.color-swatch').forEach(sw => {
            sw.addEventListener('click', () => {
                document.getElementById('title-color-row').querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'));
                sw.classList.add('active');
                cfg.titleColor = sw.dataset.color;
                scheduleUpdate();
            });
        });

        // Range inputs
        ['cols','gap','radius'].forEach(id => {
            document.getElementById(id).addEventListener('input', () => {
                cfg[id] = +document.getElementById(id).value;
            });
        });

        // Text inputs
        document.getElementById('poster-title').addEventListener('input', e => { cfg.title = e.target.value; });
        document.getElementById('poster-subtitle').addEventListener('input', e => { cfg.subtitle = e.target.value; });
        document.getElementById('bg-solid-color').addEventListener('input', e => { cfg.bgColor = e.target.value; scheduleUpdate(); });
    }

    function setTitleColor(color) {
        cfg.titleColor = color;
        document.getElementById('title-color-row').querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'));
        scheduleUpdate();
    }

    // ── 防抖更新 ──
    function scheduleUpdate() {
        clearTimeout(updateTimer);
        updateTimer = setTimeout(updatePreview, 120);
    }

    // ── 取得遊戲清單 ──
    async function getGameList() {
        let names = [];
        const manual = document.getElementById('manual-games').value.trim();
        if (manual) {
            names = manual.split('\n').map(s => s.trim()).filter(Boolean);
        } else if (selectedCollection) {
            names = selectedCollection.games || [];
        } else if (currentUser) {
            names = [...(currentUser.liked_games || [])].slice(0, 30);
        }
        names = [...new Set(names)].slice(0, 50);
        return names;
    }

    function getGameInfo(name) {
        const n = (name || '').trim().toLowerCase();
        return gameDatabase.find(g =>
            (g.name_zh || '').toLowerCase() === n ||
            (g.name_en || '').toLowerCase() === n ||
            (g.name_ja || '').toLowerCase() === n
        ) || null;
    }

    // 透過 Jina proxy 把圖片轉為 blob URL（繞過 CORS）
    async function fetchImageAsBlob(url) {
        if (!url) return null;
        if (preloadedImages[url]) return preloadedImages[url];
        try {
            // 嘗試 Jina 代理
            const proxyUrl = `https://r.jina.ai/${url}`;
            const r = await fetch(proxyUrl);
            if (!r.ok) throw new Error('proxy failed');
            const blob = await r.blob();
            if (!blob.type.startsWith('image/')) throw new Error('not image');
            const objUrl = URL.createObjectURL(blob);
            preloadedImages[url] = objUrl;
            return objUrl;
        } catch(e) {
            // 直接嘗試
            try {
                const r2 = await fetch(url);
                if (!r2.ok) throw new Error('direct failed');
                const blob2 = await r2.blob();
                const objUrl2 = URL.createObjectURL(blob2);
                preloadedImages[url] = objUrl2;
                return objUrl2;
            } catch(e2) {
                preloadedImages[url] = null; // 快取失敗
                return null;
            }
        }
    }

    // ── 建立 Poster DOM ──
    async function buildPosterDOM(names) {
        const { w, h, cols, gap, radius, fallback, showname,
                bgType, bgColor, titleColor, title, subtitle } = cfg;

        // 計算格子高度
        const contentPad = 24;
        const headerH = title ? (subtitle ? 72 : 52) : 0;
        const footerH = 24;
        const gridH = h - contentPad * 2 - headerH - footerH - (headerH > 0 ? 16 : 0);
        const rows   = Math.ceil(names.length / cols);
        const cellW  = (w - contentPad * 2 - gap * (cols - 1)) / cols;
        const cellH  = Math.max(60, (gridH - gap * (rows - 1)) / rows);

        // 預先載入圖片（最多並發 6）
        const gameInfoList = names.map(n => ({ name: n, info: getGameInfo(n) }));
        const imgUrls = gameInfoList.map(g => g.info?.image_url || null);
        const blobUrls = await Promise.all(imgUrls.map(u => u ? fetchImageAsBlob(u) : Promise.resolve(null)));

        // 背景
        let bgCss = '';
        if (bgType === 'gradient-dark')  bgCss = 'background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%)';
        else if (bgType === 'gradient-light') bgCss = 'background: linear-gradient(135deg, #f8fafc 0%, #ede9fe 50%, #fce7f3 100%)';
        else if (bgType === 'solid')     bgCss = `background: ${bgColor}`;
        else if (bgType === 'blur-mosaic') {
            // 用遊戲圖片做模糊背景
            const firstImg = blobUrls.find(u => u);
            bgCss = firstImg
                ? `background: url('${firstImg}') center/cover; filter: blur(20px) brightness(0.5); transform:scale(1.2)`
                : 'background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%)';
        }

        // 決定文字大小
        const titleSize = title.length > 16 ? 28 : title.length > 10 ? 34 : 40;

        // 格子 HTML
        const cellsHtml = gameInfoList.map(({ name, info }, i) => {
            const blobUrl = blobUrls[i];
            const nameLabel = info?.name_zh || name;
            const showNameCss = showname === 'always' ? 'display:block' : 'display:none';

            let innerHtml = '';
            if (blobUrl) {
                innerHtml = `<img src="${blobUrl}" alt="${nameLabel}" style="width:100%;height:100%;object-fit:cover;display:block;">`;
            } else {
                // fallback 處理
                const fallbackColors = {
                    dark:  `background: #1e1b4b`,
                    light: `background: #e0e7ff`,
                    bw:    `background: linear-gradient(135deg,#2d2d2d,#555)`,
                    blur:  `background: linear-gradient(135deg, hsl(${(i*47)%360},50%,25%), hsl(${(i*47+120)%360},60%,30%))`,
                    name:  `background: #1e1b4b`,
                };
                const emoji = ['🎲','🃏','♟️','🎯','🧩','🎭','🏆','⚔️','🌍','🔮'][ i % 10 ];
                innerHtml = `
                    <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;flex-direction:column;${fallbackColors[fallback]||fallbackColors.blur}">
                        ${fallback !== 'name' ? `<div style="font-size:${Math.min(cellH, cellW)*0.32}px;opacity:0.6;">${emoji}</div>` : ''}
                        ${fallback === 'name' || fallback === 'blur' ? `<div style="font-size:${Math.min(12, cellW*0.1)}px;color:rgba(255,255,255,0.7);font-weight:700;text-align:center;padding:0 4px;word-break:break-all;">${nameLabel}</div>` : ''}
                    </div>`;
            }

            return `
                <div style="
                    width:${cellW}px; height:${cellH}px;
                    border-radius:${radius}px;
                    overflow:hidden; position:relative; flex-shrink:0;
                    flex: 0 0 ${cellW}px;
                ">
                    ${innerHtml}
                    <div style="${showNameCss};position:absolute;bottom:0;left:0;right:0;
                        font-size:10px;padding:3px 5px;
                        background:rgba(0,0,0,0.6);color:white;
                        text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                        ${nameLabel}
                    </div>
                </div>`;
        }).join('');

        const gridHtml = `
            <div style="
                display:grid;
                grid-template-columns:repeat(${cols}, 1fr);
                gap:${gap}px;
                width:${w - contentPad*2}px;
            ">
                ${cellsHtml}
            </div>`;

        const headerHtml = title ? `
            <div style="margin-bottom:16px;">
                <div style="font-size:${titleSize}px;font-weight:900;color:${titleColor};line-height:1.15;word-break:break-word;font-family:'Inter',sans-serif;">${title}</div>
                ${subtitle ? `<div style="font-size:16px;color:${titleColor};opacity:0.75;margin-top:6px;line-height:1.4;word-break:break-word;font-family:'Inter',sans-serif;">${subtitle}</div>` : ''}
            </div>` : '';

        // 模糊背景處理（blur-mosaic 的 bg div 要在外層）
        const needBgLayer = bgType === 'blur-mosaic';
        const bgDiv = needBgLayer
            ? `<div style="position:absolute;inset:0;z-index:0;${bgCss};"></div>`
            : '';

        const posterHtml = `
            <div id="poster-root" style="
                width:${w}px; height:${h}px;
                position:relative; overflow:hidden;
                ${!needBgLayer ? bgCss : ''}
                font-family:'Inter',sans-serif;
            ">
                ${bgDiv}
                <div style="position:relative;z-index:1;padding:${contentPad}px;display:flex;flex-direction:column;height:100%;width:100%;">
                    ${headerHtml}
                    <div style="flex:1;display:flex;align-items:flex-start;">
                        ${gridHtml}
                    </div>
                    <div style="margin-top:8px;font-size:11px;opacity:0.4;text-align:right;color:${titleColor};font-family:'Inter',sans-serif;">
                        MBTI × 桌遊配對
                    </div>
                </div>
            </div>`;

        return posterHtml;
    }

    // ── 更新預覽 ──
    async function updatePreview() {
        const names = await getGameList();
        if (names.length === 0) {
            document.getElementById('poster-container').innerHTML = `
                <div style="aspect-ratio:1;display:flex;align-items:center;justify-content:center;background:#111;color:#666;flex-direction:column;gap:0.75rem;padding:2rem;">
                    <div style="font-size:2.5rem;">📋</div>
                    <div>選擇一個清單或輸入遊戲名稱</div>
                </div>`;
            return;
        }
        currentGames = names;

        const html = await buildPosterDOM(names);
        const container = document.getElementById('poster-container');

        // 縮放預覽（poster 原始尺寸可能很大）
        const previewWidth = container.offsetWidth || 600;
        const scale = previewWidth / cfg.w;

        container.innerHTML = `
            <div style="
                width:${previewWidth}px;
                height:${cfg.h * scale}px;
                overflow:hidden; position:relative;
            ">
                <div style="
                    transform-origin:top left;
                    transform:scale(${scale});
                    width:${cfg.w}px;
                    height:${cfg.h}px;
                ">
                    ${html}
                </div>
            </div>`;

        document.getElementById('preview-label').textContent =
            `預覽 ${cfg.w}×${cfg.h}px・${names.length} 款遊戲`;
    }

    // ── 下載 ──
    async function downloadPoster() {
        const names = await getGameList();
        if (names.length === 0) { alert('請先選擇清單或輸入遊戲名稱'); return; }

        showLoading('生成中，請稍候...');

        try {
            const html = await buildPosterDOM(names);

            // 建立離屏 div
            const offscreen = document.createElement('div');
            offscreen.style.cssText = 'position:fixed;left:-99999px;top:0;z-index:-1;';
            offscreen.innerHTML = html;
            document.body.appendChild(offscreen);
            const posterEl = offscreen.querySelector('#poster-root');

            // 等待圖片載入
            await new Promise(resolve => {
                const imgs = posterEl.querySelectorAll('img');
                if (imgs.length === 0) { resolve(); return; }
                let loaded = 0;
                imgs.forEach(img => {
                    if (img.complete) { if (++loaded === imgs.length) resolve(); }
                    else {
                        img.onload = img.onerror = () => { if (++loaded === imgs.length) resolve(); };
                    }
                });
                setTimeout(resolve, 5000); // fallback timeout
            });

            // html2canvas
            const canvas = await html2canvas(posterEl, {
                scale: cfg.scale,
                useCORS: true,
                allowTaint: true,
                backgroundColor: null,
                logging: false,
                width: cfg.w,
                height: cfg.h,
            });

            document.body.removeChild(offscreen);

            // 下載
            canvas.toBlob(blob => {
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `${cfg.title || '桌遊清單'}_${cfg.w}x${cfg.h}.png`;
                a.click();
                URL.revokeObjectURL(url);
                hideLoading();
                document.getElementById('export-status').textContent = '✅ 下載成功！';
                setTimeout(() => document.getElementById('export-status').textContent = '', 3000);
            }, 'image/png');

        } catch(e) {
            hideLoading();
            console.error(e);
            document.getElementById('export-status').textContent = '❌ 生成失敗，請重試';
        }
    }

    async function copyPoster() {
        const names = await getGameList();
        if (names.length === 0) { alert('請先選擇清單或輸入遊戲名稱'); return; }

        if (!navigator.clipboard?.write) {
            alert('您的瀏覽器不支援複製到剪貼簿，請使用下載功能');
            return;
        }

        showLoading('複製中...');
        try {
            const html = await buildPosterDOM(names);
            const offscreen = document.createElement('div');
            offscreen.style.cssText = 'position:fixed;left:-99999px;top:0;z-index:-1;';
            offscreen.innerHTML = html;
            document.body.appendChild(offscreen);
            const posterEl = offscreen.querySelector('#poster-root');

            await new Promise(resolve => {
                const imgs = posterEl.querySelectorAll('img');
                if (imgs.length === 0) { resolve(); return; }
                let loaded = 0;
                imgs.forEach(img => {
                    if (img.complete) { if (++loaded === imgs.length) resolve(); }
                    else { img.onload = img.onerror = () => { if (++loaded === imgs.length) resolve(); }; }
                });
                setTimeout(resolve, 5000);
            });

            const canvas = await html2canvas(posterEl, {
                scale: Math.min(cfg.scale, 2),
                useCORS: true, allowTaint: true, backgroundColor: null, logging: false,
                width: cfg.w, height: cfg.h,
            });
            document.body.removeChild(offscreen);

            canvas.toBlob(async blob => {
                try {
                    await navigator.clipboard.write([new ClipboardItem({ 'image/png': blob })]);
                    hideLoading();
                    document.getElementById('export-status').textContent = '✅ 已複製到剪貼簿！';
                    setTimeout(() => document.getElementById('export-status').textContent = '', 3000);
                } catch(ce) {
                    hideLoading();
                    document.getElementById('export-status').textContent = '❌ 複製失敗，請嘗試下載';
                }
            }, 'image/png');
        } catch(e) {
            hideLoading();
            console.error(e);
        }
    }

    function showLoading(msg) {
        document.getElementById('loading-text').textContent = msg || '生成中...';
        document.getElementById('loading-overlay').style.display = 'flex';
        document.getElementById('download-btn').disabled = true;
    }
    function hideLoading() {
        document.getElementById('loading-overlay').style.display = 'none';
        document.getElementById('download-btn').disabled = false;
    }
    </script>
</body>
</html>
