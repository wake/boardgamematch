<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>遊戲管理 - MBTI × 桌遊配對</title>
    <link rel="stylesheet" href="css/styles.css">
    <link rel="stylesheet" href="css/hourglass-simple.css">
    <style>
        .admin-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 2rem;
            margin-bottom: 2rem;
            border-radius: 1rem;
        }
        
        .search-bar {
            margin-bottom: 2rem;
            display: flex;
            gap: 1rem;
        }
        
        .search-bar input {
            flex: 1;
            padding: 0.75rem 1rem;
            border: 1px solid var(--border-color);
            border-radius: 0.5rem;
            font-size: 1rem;
        }
        
        .game-table {
            background: var(--card-bg);
            border-radius: 1rem;
            overflow-x: auto;   /* 手機橫向捲動備用 */
            box-shadow: var(--shadow-md);
        }

        /* 手機：隱藏次要欄位，放大按鈕 */
        @media (max-width: 768px) {
            .col-year, .col-players, .col-time, .col-complexity, .col-source {
                display: none;
            }
            .btn-small {
                padding: 0.6rem 1.1rem;
                font-size: 1rem;
            }
            td, th { padding: 0.75rem 0.5rem; }
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
        }
        
        thead {
            background: var(--bg-light);
        }
        
        th {
            padding: 1rem;
            text-align: left;
            font-weight: 600;
            color: var(--text-color);
            border-bottom: 2px solid var(--border-color);
        }
        
        td {
            padding: 1rem;
            border-bottom: 1px solid var(--border-color);
        }
        
        tr:hover {
            background: var(--bg-light);
        }
        
        .game-icon {
            font-size: 2rem;
            text-align: center;
        }
        
        .game-name {
            font-weight: 600;
            color: var(--text-color);
        }
        
        .game-name-en {
            font-size: 0.9rem;
            color: var(--text-light);
            margin-top: 0.25rem;
        }
        
        .complexity-stars {
            color: #f39c12;
        }
        
        .btn-actions {
            display: flex;
            gap: 0.5rem;
        }
        
        .btn-small {
            padding: 0.5rem 1rem;
            border: none;
            border-radius: 0.5rem;
            cursor: pointer;
            font-size: 0.9rem;
            transition: all 0.3s;
        }
        
        .btn-edit {
            background: #3498db;
            color: white;
        }
        
        .btn-delete {
            background: #e74c3c;
            color: white;
        }
        
        .add-game-btn {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            padding: 1rem 2rem;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 2rem;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
            transition: all 0.3s;
        }
        
        .add-game-btn:hover {
            transform: translateY(-4px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.6);
        }
        
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }
        
        .modal.active {
            display: flex;
        }
        
        .modal-content {
            background: white;
            border-radius: 1rem;
            padding: 2rem;
            max-width: 800px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
        }
        
        .form-group {
            margin-bottom: 1.5rem;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            color: var(--text-color);
        }
        
        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid var(--border-color);
            border-radius: 0.5rem;
            font-size: 1rem;
        }
        
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }
    </style>
    <!-- Google Sign-In SDK -->
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    
    <!-- 管理後台驗證 -->
    <script src="js/admin-auth.js?v=20240222-fix"></script>
</head>
<body>
    <!-- 導覽列 -->
    <nav class="navbar">
        <div class="navbar-container">
            <a href="index.html" class="navbar-logo">
                <div class="navbar-logo-text" style="display:flex;flex-direction:column;line-height:1.3;">
                    <span style="display:block;font-size:1.1rem;font-weight:700;">MBTI ×</span>
                    <span style="display:block;font-size:1.1rem;font-weight:700;">桌遊配對</span>
                </div>
            </a>
            <ul class="navbar-menu">
                <li><a href="index.html">回到首頁</a></li>
                <li><a href="explore.html">玩家數據</a></li>
                <li><a href="recommend.html">桌遊探索</a></li>
                <li><a href="leaderboard.html">貢獻排行</a></li>
                <li><a href="profile.html">我的檔案</a></li>
            </ul>
        </div>
    </nav>

    <div class="container">
        <!-- 頁首 -->
        <div class="admin-header">
            <h2 style="margin: 0 0 0.5rem 0;">🎮 遊戲資料管理</h2>
            <p style="margin: 0 0 1rem 0; opacity: 0.9;">管理遊戲資料庫中的所有桌遊資訊</p>
            <a href="admin.html" class="btn btn-secondary" style="background:rgba(255,255,255,0.2); color:white; border:1px solid rgba(255,255,255,0.4);">← 返回管理後台</a>
        </div>

        <!-- 統計資訊 -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
            <div style="background: var(--card-bg); padding: 1.5rem; border-radius: 1rem; text-align: center;">
                <div style="font-size: 2rem; font-weight: bold; color: var(--primary-color);" id="total-games">-</div>
                <div style="color: var(--text-light);">總遊戲數</div>
            </div>
            <div style="background: var(--card-bg); padding: 1.5rem; border-radius: 1rem; text-align: center;">
                <div style="font-size: 2rem; font-weight: bold; color: #27ae60;" id="bgg-games">-</div>
                <div style="color: var(--text-light);">BGG 遊戲</div>
            </div>
            <div style="background: var(--card-bg); padding: 1.5rem; border-radius: 1rem; text-align: center;">
                <div style="font-size: 2rem; font-weight: bold; color: #e74c3c;" id="manual-games">-</div>
                <div style="color: var(--text-light);">手動新增</div>
            </div>
        </div>

        <!-- 搜尋列 -->
        <div class="search-bar">
            <input type="text" id="search-input" placeholder="🔍 搜尋遊戲名稱..." onkeyup="filterGames()">
            <select id="source-filter" onchange="filterGames()">
                <option value="">全部來源</option>
                <option value="BGG">BGG</option>
                <option value="manual">手動新增</option>
            </select>
        </div>

        <!-- 遊戲列表 -->
        <div class="game-table">
            <table>
                <thead>
                    <tr>
                        <th style="width: 60px;">圖示</th>
                        <th>遊戲名稱</th>
                        <th class="col-year" style="width: 80px;">年份</th>
                        <th class="col-players" style="width: 90px;">玩家數</th>
                        <th class="col-time" style="width: 80px;">時間</th>
                        <th class="col-complexity" style="width: 90px;">複雜度</th>
                        <th class="col-source" style="width: 90px;">來源</th>
                        <th style="width: 120px;">操作</th>
                    </tr>
                </thead>
                <tbody id="game-list">
                    <!-- 動態插入 -->
                </tbody>
            </table>
        </div>
    </div>

    <!-- 新增/編輯遊戲彈窗 -->
    <div class="modal" id="game-modal">
        <div class="modal-content">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h2 id="modal-title">新增遊戲</h2>
                <button onclick="closeModal()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer;">✕</button>
            </div>
            
            <form id="game-form" onsubmit="saveGame(event)">

                <!-- BGG ID 快速抓取區 -->
                <div style="background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 0.75rem; padding: 1rem; margin-bottom: 1.25rem;">
                    <div style="display:flex; gap:0.75rem; align-items:flex-end; flex-wrap:wrap;">
                        <div style="flex:1; min-width:160px;">
                            <label style="display:block; margin-bottom:0.35rem; font-weight:600; font-size:0.9rem;">🔢 BGG ID</label>
                            <input type="text" id="game-bgg-id" placeholder="例：174430" oninput="updateSearchHint(); checkBggDuplicate()" style="width:100%; padding:0.55rem 0.75rem; border:1px solid var(--border-color); border-radius:0.5rem; font-size:0.95rem;">
                        </div>
                        <button type="button" onclick="fetchFromBGG()" id="bgg-fetch-btn"
                            style="padding:0.55rem 1.1rem; background:linear-gradient(135deg,#667eea,#764ba2); color:white; border:none; border-radius:0.5rem; cursor:pointer; font-size:0.9rem; white-space:nowrap;">
                            🔍 從 BGG 抓取資料
                        </button>
                    </div>
                    <div style="margin-top:0.5rem; font-size:0.78rem; color:var(--text-light);">
                        📋 可自動填入：英文名稱、發行年份、玩家數、遊戲時間、複雜度、封面圖片、遊戲描述、中文名稱（DuckDuckGo 搜尋）
                    </div>
                    <div id="bgg-fetch-status" style="margin-top:0.4rem; font-size:0.85rem; color:var(--text-light); min-height:1.2em;"></div>
                    <div id="bgg-duplicate-warning" style="display:none; margin-top:0.5rem; padding:0.6rem 0.85rem; background:#fff3cd; border:1px solid #ffc107; border-radius:0.5rem; font-size:0.85rem; color:#856404;"></div>
                    <div id="bgg-search-hint" style="margin-top:0.4rem; font-size:0.82rem; display:none;">
                        🔎 找中文名：
                        <a id="bgg-google-link" href="#" target="_blank" style="color:var(--primary-color);">Google 搜尋</a>
                        ·
                        <a id="bgg-page-link" href="#" target="_blank" style="color:var(--primary-color);">BGG 版本頁</a>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>中文名稱</label>
                        <input type="text" id="game-name-zh" placeholder="（可留空）">
                    </div>
                    <div class="form-group">
                        <label>日文名稱</label>
                        <input type="text" id="game-name-ja" placeholder="（可留空）">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>英文名稱</label>
                        <input type="text" id="game-name-en">
                    </div>
                    <div class="form-group">
                        <label>發行年份</label>
                        <input type="number" id="game-year" min="1900" max="2099">
                    </div>
                </div>

                <!-- 封面圖片 -->
                <div class="form-group">
                    <label>🖼️ 封面圖片 URL</label>
                    <div style="display:flex; gap:0.6rem; align-items:center;">
                        <input type="text" id="game-image-url" placeholder="https://cf.geekdo-images.com/..." style="flex:1;">
                        <div id="image-preview" style="width:48px; height:48px; border-radius:0.4rem; border:1px solid var(--border-color); overflow:hidden; flex-shrink:0; background:var(--bg-color); display:flex; align-items:center; justify-content:center; font-size:1.5rem;">🎲</div>
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label>最少玩家數</label>
                        <input type="number" id="game-min-players" min="1" max="99">
                    </div>
                    <div class="form-group">
                        <label>最多玩家數</label>
                        <input type="number" id="game-max-players" min="1" max="99">
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label>遊戲時間（分鐘）</label>
                        <input type="number" id="game-playing-time" min="1">
                    </div>
                    <div class="form-group">
                        <label>複雜度（1-5）</label>
                        <input type="number" id="game-complexity" min="1" max="5" step="0.01">
                    </div>
                </div>
                
                <div class="form-group">
                    <label>遊戲描述</label>
                    <textarea id="game-description" rows="4"></textarea>
                </div>
                
                <div class="form-group">
                    <label>資料來源</label>
                    <select id="game-source">
                        <option value="manual">手動新增</option>
                        <option value="BGG">BGG</option>
                        <option value="BGA">BGA</option>
                    </select>
                </div>
                
                <input type="hidden" id="game-id">
                
                <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; font-size: 1.1rem;">儲存遊戲</button>
            </form>
        </div>
    </div>

    <!-- 新增按鈕 -->
    <button class="add-game-btn" onclick="openModal()">+ 新增遊戲</button>

    <!-- 🧹 後台導覽列清理（必須最先載入） -->
    <script src="js/admin-navbar-cleanup.js"></script>
    <script src="js/app.js"></script>
    <script src="js/show-admin-link.js"></script>
    <script>
        let allGames = [];
        let filteredGames = [];
        let isSuperAdmin = false;

        // 角色判斷：非超管隱藏刪除按鈕
        document.addEventListener('adminAuthenticated', (e) => {
            const role = e.detail?.role || window.AdminAuth?.getCurrentAdmin()?.role;
            isSuperAdmin = (role === 'super_admin');
            // 若已渲染，重新渲染一次套用正確按鈕
            if (filteredGames.length > 0) renderGames(filteredGames);
        });

        // 載入遊戲列表
        async function loadGames() {
            try {
                const response = await fetch('tables/game_database?limit=1000');
                const result = await response.json();
                allGames = result.data || [];
                filteredGames = allGames;
                
                // 更新統計
                document.getElementById('total-games').textContent = allGames.length;
                document.getElementById('bgg-games').textContent = allGames.filter(g => g.source === 'BGG').length;
                document.getElementById('manual-games').textContent = allGames.filter(g => g.source === 'manual').length;
                
                renderGames();
                
            } catch (error) {
                console.error('Error loading games:', error);
                alert('載入遊戲時發生錯誤');
            }
        }

        // 渲染遊戲列表
        function renderGames() {
            const tbody = document.getElementById('game-list');
            
            if (filteredGames.length === 0) {
                tbody.innerHTML = '<tr><td colspan="8" style="text-align: center; padding: 2rem; color: var(--text-light);">沒有找到遊戲</td></tr>';
                return;
            }
            
            tbody.innerHTML = filteredGames.map(game => `
                <tr>
                    <td class="game-icon" style="width:56px; padding:0.3rem;">
                        ${game.image_url && game.image_url.startsWith('http')
                            ? `<img src="${game.image_url}" style="width:48px;height:48px;object-fit:cover;border-radius:0.4rem;border:1px solid var(--border-color);" onerror="this.outerHTML='🎲'">`
                            : '<span style="font-size:1.5rem;">🎲</span>'}
                    </td>
                    <td>
                        <div class="game-name">${game.name_zh || '未命名'}</div>
                        <div class="game-name-en">${game.name_en || '-'}</div>
                    </td>
                    <td class="col-year">${game.year || '-'}</td>
                    <td class="col-players">${game.min_players && game.max_players ? `${game.min_players}-${game.max_players}` : '-'}</td>
                    <td class="col-time">${game.playing_time ? `${game.playing_time}分` : '-'}</td>
                    <td class="col-complexity complexity-stars">${game.complexity ? '★'.repeat(game.complexity) : '-'}</td>
                    <td class="col-source"><span style="padding: 0.25rem 0.75rem; background: var(--bg-light); border-radius: 0.5rem; font-size: 0.85rem;">${game.source || 'manual'}</span></td>
                    <td>
                        <div class="btn-actions">
                            <button class="btn-small btn-edit" onclick="editGame('${game.id}')">編輯</button>
                            ${isSuperAdmin ? `<button class="btn-small btn-delete" onclick="deleteGame('${game.id}', '${game.name_zh}')">刪除</button>` : ''}
                        </div>
                    </td>
                </tr>
            `).join('');
        }

        // 篩選遊戲
        function filterGames() {
            const searchText = document.getElementById('search-input').value.toLowerCase();
            const sourceFilter = document.getElementById('source-filter').value;
            
            filteredGames = allGames.filter(game => {
                const matchSearch = !searchText || 
                    (game.name_zh && game.name_zh.toLowerCase().includes(searchText)) ||
                    (game.name_en && game.name_en.toLowerCase().includes(searchText));
                
                const matchSource = !sourceFilter || game.source === sourceFilter;
                
                return matchSearch && matchSource;
            });
            
            renderGames();
        }

        // 開啟彈窗
        function openModal(gameId = null) {
            document.getElementById('modal-title').textContent = gameId ? '編輯遊戲' : '新增遊戲';
            
            if (gameId) {
                loadGameData(gameId);
            } else {
                document.getElementById('game-form').reset();
                document.getElementById('game-id').value = '';
                document.getElementById('image-preview').innerHTML = '🎲';
                setFetchStatus('', '');
            }
            
            document.getElementById('game-modal').classList.add('active');
        }

        // 關閉彈窗
        function closeModal() {
            document.getElementById('game-modal').classList.remove('active');
        }

        // 載入遊戲資料
        function loadGameData(gameId) {
            const game = allGames.find(g => g.id === gameId);
            if (!game) return;
            
            document.getElementById('game-id').value = game.id;
            document.getElementById('game-name-zh').value = game.name_zh || '';
            document.getElementById('game-name-ja').value = game.name_ja || '';
            document.getElementById('game-name-en').value = game.name_en || '';
            document.getElementById('game-image-url').value = game.image_url && game.image_url.startsWith('http') ? game.image_url : '';
            document.getElementById('game-year').value = game.year || '';
            document.getElementById('game-min-players').value = game.min_players || '';
            document.getElementById('game-max-players').value = game.max_players || '';
            document.getElementById('game-playing-time').value = game.playing_time || '';
            document.getElementById('game-complexity').value = game.complexity || '';
            document.getElementById('game-description').value = game.description || '';
            document.getElementById('game-source').value = game.source || 'manual';
            document.getElementById('game-bgg-id').value = game.bgg_id || '';
            updateImagePreview();
        }

        // 編輯遊戲
        function editGame(gameId) {
            openModal(gameId);
        }

        // ── 即時檢查 BGG ID 重複 ──
        function checkBggDuplicate() {
            const bggId = document.getElementById('game-bgg-id').value.trim();
            const currentId = document.getElementById('game-id').value; // 編輯模式時有值
            const warn = document.getElementById('bgg-duplicate-warning');
            if (!bggId || !allGames.length) { warn.style.display = 'none'; return; }
            const dup = allGames.find(g => g.bgg_id && g.bgg_id === bggId && g.id !== currentId);
            if (dup) {
                const name = dup.name_zh || dup.name_en || '(未命名)';
                warn.innerHTML = `⚠️ BGG ID <strong>${bggId}</strong> 已存在：<strong>${name}</strong>（id: ${dup.id}）<br>
                    <a href="#" onclick="editGame('${dup.id}'); return false;" style="color:#856404; text-decoration:underline;">→ 點此直接編輯該筆記錄</a>`;
                warn.style.display = 'block';
            } else {
                warn.style.display = 'none';
            }
        }

        // 儲存遊戲
        async function saveGame(event) {
            event.preventDefault();
            
            const gameId = document.getElementById('game-id').value;
            const imageUrlVal = document.getElementById('game-image-url').value.trim();
            const gameData = {
                name_zh:      document.getElementById('game-name-zh').value.trim(),
                name_ja:      document.getElementById('game-name-ja').value.trim(),
                name_en:      document.getElementById('game-name-en').value.trim(),
                image_url:    imageUrlVal || '',
                year:         parseInt(document.getElementById('game-year').value) || null,
                min_players:  parseInt(document.getElementById('game-min-players').value) || null,
                max_players:  parseInt(document.getElementById('game-max-players').value) || null,
                playing_time: parseInt(document.getElementById('game-playing-time').value) || null,
                complexity:   parseFloat(document.getElementById('game-complexity').value) || null,
                description:  document.getElementById('game-description').value.trim(),
                source:       document.getElementById('game-source').value,
                bgg_id:       document.getElementById('game-bgg-id').value.trim()
            };
            
            // ── 新增前做重複把關 ──
            if (!gameId) {
                const bggIdVal = gameData.bgg_id;
                const nameZh = gameData.name_zh.toLowerCase();
                const nameEn = gameData.name_en.toLowerCase();
                const dups = allGames.filter(g =>
                    (bggIdVal && g.bgg_id === bggIdVal) ||
                    (nameZh && g.name_zh && g.name_zh.toLowerCase() === nameZh) ||
                    (nameEn && g.name_en && g.name_en.toLowerCase() === nameEn)
                );
                if (dups.length > 0) {
                    const dupNames = dups.map(g => `「${g.name_zh || g.name_en || '(未命名)'}」(id: ${g.id})`).join('、');
                    const ok = confirm(`⚠️ 疑似重複遊戲！\n\n資料庫已有相似記錄：\n${dupNames}\n\n確定仍要新增？`);
                    if (!ok) return;
                }
            }

            try {
                if (gameId) {
                    // 更新
                    const response = await fetch(`tables/game_database/${gameId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(gameData)
                    });
                    
                    if (!response.ok) throw new Error('更新失敗');
                    alert('遊戲更新成功！');
                } else {
                    // 新增
                    gameData.id = 'game_' + Date.now();
                    gameData.created_at = Date.now();
                    
                    const response = await fetch('tables/game_database', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(gameData)
                    });
                    
                    if (!response.ok) throw new Error('新增失敗');
                    alert('遊戲新增成功！');
                }
                
                closeModal();
                loadGames();
                
            } catch (error) {
                console.error('Error saving game:', error);
                alert('儲存遊戲時發生錯誤：' + error.message);
            }
        }

        // ── 圖片預覽（即時更新縮圖） ──
        function updateImagePreview() {
            const url = document.getElementById('game-image-url').value.trim();
            const preview = document.getElementById('image-preview');
            if (!preview) return;
            if (url.startsWith('http')) {
                preview.innerHTML = `<img src="${url}" style="width:100%;height:100%;object-fit:cover;" onerror="this.parentElement.innerHTML='🎲'">`;
            } else {
                preview.innerHTML = '🎲';
            }
        }
        // 綁定即時預覽
        document.getElementById('game-image-url')?.addEventListener('input', updateImagePreview);

        // ── 從 BGG 抓取資料 ──
        async function fetchFromBGG() {
            const bggId = document.getElementById('game-bgg-id').value.trim();
            if (!bggId) {
                setFetchStatus('❌ 請先填入 BGG ID', 'red');
                return;
            }

            const btn = document.getElementById('bgg-fetch-btn');
            btn.disabled = true;
            btn.textContent = '⏳ 抓取中...';
            setFetchStatus('正在透過 Jina proxy 讀取 BGG 頁面...', '#888');

            try {
                // 用 Jina proxy 讀 BGG 遊戲頁
                const pageUrl = `https://boardgamegeek.com/boardgame/${bggId}`;
                const proxyUrl = `https://r.jina.ai/${pageUrl}`;
                const res = await fetch(proxyUrl, { headers: { 'X-No-Cache': 'true' } });
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                const text = await res.text();

                let filled = [];

                // ── 抓英文名稱 ──
                const titleMatch = text.match(/^#\s+(.+)/m);
                if (titleMatch) {
                    const title = titleMatch[1].replace(/\s*\(\d{4}\)\s*$/, '').trim();
                    if (title && !document.getElementById('game-name-en').value) {
                        document.getElementById('game-name-en').value = title;
                        filled.push('英文名稱');
                    }
                }

                // ── 抓年份 ──
                const yearMatch = text.match(/\b(19|20)\d{2}\b/);
                if (yearMatch && !document.getElementById('game-year').value) {
                    document.getElementById('game-year').value = yearMatch[0];
                    filled.push('年份');
                }

                // ── 抓玩家數 ──
                const playersMatch = text.match(/(\d+)\s*[–\-~]\s*(\d+)\s*[Pp]layers?/);
                if (playersMatch) {
                    if (!document.getElementById('game-min-players').value) {
                        document.getElementById('game-min-players').value = playersMatch[1];
                        filled.push('最少玩家');
                    }
                    if (!document.getElementById('game-max-players').value) {
                        document.getElementById('game-max-players').value = playersMatch[2];
                        filled.push('最多玩家');
                    }
                }

                // ── 抓遊戲時間 ──
                const timeMatch = text.match(/(\d+)\s*[–\-~]\s*(\d+)\s*[Mm]in|(\d+)\s*[Mm]inutes?/);
                if (timeMatch && !document.getElementById('game-playing-time').value) {
                    const t = timeMatch[2] || timeMatch[3];
                    document.getElementById('game-playing-time').value = t;
                    filled.push('遊戲時間');
                }

                // ── 抓複雜度（格式：「4.44 / 5」）──
                const weightMatch = text.match(/(\d+\.\d+)\s*\/\s*5/);
                if (weightMatch && !document.getElementById('game-complexity').value) {
                    document.getElementById('game-complexity').value = parseFloat(weightMatch[1]).toFixed(2);
                    filled.push(`複雜度 ${weightMatch[1]}`);
                }

                // ── 抓圖片 ──
                const imgRegex = /https:\/\/cf\.geekdo-images\.com\/[^\s"']+\.(?:jpg|png|jpeg)/gi;
                const candidates = [];
                let m;
                while ((m = imgRegex.exec(text)) !== null) candidates.push(m[0]);

                let imgUrl = candidates.find(u => u.includes('_original'))
                          || candidates.find(u => !u.includes('user') && !u.includes('avatar')
                                               && !u.includes('micro') && !u.includes('square')
                                               && !u.includes('thumb'))
                          || candidates[0]
                          || null;

                if (imgUrl) {
                    document.getElementById('game-image-url').value = imgUrl;
                    updateImagePreview();
                    filled.push('封面圖片');
                }

                // ── 抓遊戲描述（英文 → Jina 翻譯濃縮成繁體中文 20 字內）──
                if (!document.getElementById('game-description').value) {
                    let rawEnDesc = null;

                    // 策略1：找標題後的第一個較長段落（至少 40 字元）
                    const descMatch = text.match(/^#{1,2}\s+.+\n{1,3}([\s\S]+?)(?=\n#{1,3}\s|\n---|\n\*\*\*)/m);
                    if (descMatch) {
                        const raw = descMatch[1]
                            .replace(/!\[.*?\]\(.*?\)/g, '')
                            .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
                            .replace(/\*\*([^*]+)\*\*/g, '$1')
                            .replace(/\*([^*]+)\*/g, '$1')
                            .replace(/\n+/g, ' ')
                            .trim();
                        if (raw.length >= 40) rawEnDesc = raw.slice(0, 300);
                    }

                    // 策略2：找 "Description" 段落
                    if (!rawEnDesc) {
                        const descSection = text.match(/#+\s*Description\s*\n+([\s\S]+?)(?=\n#)/i);
                        if (descSection) {
                            const raw = descSection[1]
                                .replace(/!\[.*?\]\(.*?\)/g, '')
                                .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
                                .replace(/\*\*([^*]+)\*\*/g, '$1')
                                .replace(/\n+/g, ' ')
                                .trim();
                            if (raw.length >= 30) rawEnDesc = raw.slice(0, 300);
                        }
                    }

                    if (rawEnDesc) {
                        // 用 Jina 翻譯並濃縮：送一個提示讓 Jina 讀到的頁面包含指令
                        // 原理：透過 r.jina.ai 讀取一個包含翻譯指令的 URL（DuckDuckGo 搜尋結果）
                        // 實際上使用 Jina 的 s.jina.ai（搜尋）傳入「請翻譯並濃縮」的 query
                        let zhDesc = null;
                        try {
                            setFetchStatus('🈯 翻譯描述中（Jina）...', '#888');
                            // 用 Jina search 傳入指令，讓它自動摘要翻譯
                            const prompt = `以下是一款桌遊的英文描述，請翻譯成繁體中文並濃縮成20字以內的核心玩法介紹（不要加引號或標點以外的符號）：${rawEnDesc.slice(0, 200)}`;
                            const jinaSearchUrl = `https://s.jina.ai/${encodeURIComponent(prompt)}`;
                            const tRes = await fetch(jinaSearchUrl, {
                                headers: { 'Accept': 'text/plain', 'X-No-Cache': 'true' }
                            });
                            if (tRes.ok) {
                                const tText = await tRes.text();
                                // 從回傳的搜尋結果中，找第一段有中文字符且不超過30字的文字
                                // Jina search 通常回傳 markdown 格式
                                const lines = tText.split('\n').map(l => l.trim()).filter(Boolean);
                                for (const line of lines) {
                                    // 找含有中文的行，且長度在 5~30 字之間
                                    const zhMatch = line.match(/^[^#\[\]|*>]{5,30}$/) && /[\u4e00-\u9fff]/.test(line);
                                    if (zhMatch) {
                                        // 清除可能的標點符號殘留
                                        const cleaned = line.replace(/^[\s\-*•]+/, '').trim();
                                        if (cleaned.length >= 5 && cleaned.length <= 30 && /[\u4e00-\u9fff]/.test(cleaned)) {
                                            zhDesc = cleaned;
                                            break;
                                        }
                                    }
                                }
                                // 備援：找最短的一行中文摘要（通常 Jina 搜尋摘要是短句）
                                if (!zhDesc) {
                                    const zhLines = lines.filter(l =>
                                        /[\u4e00-\u9fff]{4,}/.test(l) &&
                                        l.length <= 35 &&
                                        !/^(Title|URL|https?|Source|\[)/.test(l)
                                    );
                                    if (zhLines.length > 0) {
                                        zhDesc = zhLines[0].replace(/^[\s\-*•]+/, '').slice(0, 30).trim();
                                    }
                                }
                            }
                        } catch(e) { /* 翻譯失敗不影響其他資料 */ }

                        if (zhDesc) {
                            document.getElementById('game-description').value = zhDesc;
                            filled.push(`遊戲描述（中）`);
                        } else {
                            // 翻譯失敗：直接填英文描述的前 100 字，管理員再手動翻
                            document.getElementById('game-description').value = rawEnDesc.slice(0, 100);
                            filled.push('遊戲描述（英文，請手動翻譯濃縮）');
                        }
                    }
                }

                // ── 抓中文名稱（DuckDuckGo 搜尋，最可靠的方式）──
                if (!document.getElementById('game-name-zh').value) {
                    let chineseName = null;

                    // 輔助：從搜尋結果文字中提取中文遊戲名
                    function extractChineseGameName(dText, enGameName) {
                        // 找出英文名中最具辨識性的關鍵字（排除冠詞）
                        const enKeyword = (enGameName.split(/[\s:：]+/).find(w => w.length > 3 && !/^(the|a|an|of|in|at)$/i.test(w)) || enGameName).replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

                        // 策略1: 找 "中文名（含：或·）+ 空格 + The/英文" 格式
                        // 例: 抵抗組織：阿瓦隆 The **Resistance**... 或 抵抗組織：阿瓦隆 (**Avalon**)
                        const p1 = new RegExp(`([\\u4e00-\\u9fff][\\u4e00-\\u9fff\\uff1a：:·\\-–\\s]{0,15}[\\u4e00-\\u9fff])\\s*(?:The\\s+|\\*\\*${enKeyword}|\\(\\*\\*${enKeyword}|繁體|簡體|Board)`, 'i');
                        const m1 = dText.match(p1);
                        if (m1) return m1[1].trim();

                        // 策略2: ### 標題中「中文（含：或多字）+ 空格 + 英文」的格式
                        // 例: ### 【Fun.樂桌遊】抵抗組織：阿瓦隆 The Resistance...
                        // 例: ### 阿瓦隆 The Resistance: Avalon - 香港桌上遊戲
                        const headingMatches = [...dText.matchAll(/###\s+([^\n\[]{3,60})/g)];
                        for (const hm of headingMatches) {
                            const content = hm[1]
                                .replace(/^\【[^\】]*\】\s*/, '')  // 去除開頭【標記】
                                .replace(/^\[[^\]]*\]\s*/, '');    // 去除開頭[標記]
                            // 取冒號後的中文部分，或含中文冒號的完整名稱
                            const zhPart = content.match(/^([\u4e00-\u9fff][^\s]*[\u4e00-\u9fff\uff1a：:]{0,1}[\u4e00-\u9fff]*)/);
                            if (zhPart && zhPart[1].length >= 2) return zhPart[1].trim();
                        }

                        // 策略3: 找含「：」的中文名（如「抵抗組織：阿瓦隆」）
                        const m3 = dText.match(/([\u4e00-\u9fff]{2,8}[\uff1a：:][^\n\[,，。．\s]{1,8}[\u4e00-\u9fff]{1,8})/);
                        if (m3) return m3[1].trim();

                        // 策略4: 《》書名號（可能是簡體）
                        const m4 = dText.match(/[《]([\u4e00-\u9fff：:·\-–—\s]{2,15})[》]/);
                        if (m4) return m4[1].trim();

                        return null;
                    }

                    try {
                        setFetchStatus('🔍 搜尋中文名稱（DuckDuckGo）...', '#888');
                        const enName = document.getElementById('game-name-en').value.trim();
                        const q = encodeURIComponent(`${enName || 'BGG ' + bggId} 中文名 桌遊`);
                        const dRes = await fetch(
                            `https://r.jina.ai/https://duckduckgo.com/?q=${q}&ia=web`,
                            { headers: { 'X-No-Cache': 'true' } }
                        );
                        if (dRes.ok) {
                            const dText = await dRes.text();
                            chineseName = extractChineseGameName(dText, enName || bggId);
                        }
                    } catch(e) { /* 靜默失敗 */ }

                    if (chineseName) {
                        document.getElementById('game-name-zh').value = chineseName;
                        filled.push('中文名稱');
                    }
                }

                // ── 設定來源為 BGG ──
                document.getElementById('game-source').value = 'BGG';

                if (filled.length > 0) {
                    const zhHint = document.getElementById('game-name-zh').value ? '' : '（中文名未找到，請手動填寫）';
                    setFetchStatus(`✅ 已填入：${filled.join('、')}${zhHint}`, 'green');
                } else {
                    setFetchStatus('⚠️ 頁面已讀取，但未能解析出資料，請手動填寫', 'orange');
                }

            } catch (err) {
                console.error('BGG fetch error:', err);
                setFetchStatus('❌ 抓取失敗：' + err.message, 'red');
            } finally {
                btn.disabled = false;
                btn.textContent = '🔍 從 BGG 抓取資料';
                updateSearchHint();
                checkBggDuplicate(); // 抓取完成後同步檢查重複
            }
        }

        function setFetchStatus(msg, color) {
            const el = document.getElementById('bgg-fetch-status');
            if (el) { el.textContent = msg; el.style.color = color || 'var(--text-light)'; }
        }

        function updateSearchHint() {
            const bggId  = document.getElementById('game-bgg-id').value.trim();
            const nameEn = document.getElementById('game-name-en').value.trim();
            const hint   = document.getElementById('bgg-search-hint');
            if (!hint) return;
            if (!bggId && !nameEn) { hint.style.display = 'none'; return; }

            hint.style.display = 'block';
            const q = nameEn ? `${nameEn} 中文名 桌遊` : `BGG ${bggId} 中文名 桌遊`;
            document.getElementById('bgg-google-link').href =
                `https://www.google.com/search?q=${encodeURIComponent(q)}`;
            document.getElementById('bgg-page-link').href = bggId
                ? `https://boardgamegeek.com/boardgame/${bggId}/versions`
                : '#';
        }

        // 刪除遊戲
        async function deleteGame(gameId, gameName) {
            if (!confirm(`確定要刪除「${gameName}」嗎？\n\n注意：此操作無法復原！`)) {
                return;
            }
            
            try {
                const response = await fetch(`tables/game_database/${gameId}`, {
                    method: 'DELETE'
                });
                
                if (!response.ok) throw new Error('刪除失敗');
                
                alert('遊戲已刪除！');
                loadGames();
                
            } catch (error) {
                console.error('Error deleting game:', error);
                alert('刪除遊戲時發生錯誤：' + error.message);
            }
        }

        // 點擊彈窗外部關閉
        document.getElementById('game-modal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeModal();
            }
        });

        // 初始化
        loadGames();
    </script>
</body>
</html>
