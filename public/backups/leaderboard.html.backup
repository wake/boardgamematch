<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>貢獻排行 - MBTI × 桌遊配對</title>
    <link rel="stylesheet" href="css/styles.css">
    <link rel="stylesheet" href="css/gamification.css">
    <link rel="stylesheet" href="css/hourglass-simple.css">
</head>
<body>
    <!-- 導覽列 -->
    <nav class="navbar">
        <div class="navbar-container">
            <a href="index.html" class="navbar-logo">
                <span>🎲</span>
                MBTI × 桌遊配對
            </a>
            <ul class="navbar-menu">
                <li><a href="index.html">回到首頁</a></li>
                <li><a href="explore.html">玩家數據</a></li>
                <li><a href="recommend.html">桌遊探索</a></li>
                <li><a href="leaderboard.html" class="active">貢獻排行</a></li>
                <li><a href="profile.html">我的檔案</a></li>
            </ul>
        </div>
    </nav>

    <!-- 主要內容 -->
    <div class="container">
        <div class="page-header">
            <h1 class="page-title">貢獻排行</h1>
            <p class="page-subtitle">查看社群貢獻排名，激勵彼此成長</p>
        </div>

        <!-- 排行榜切換標籤 -->
        <div style="display: flex; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap;">
            <button id="tab-weekly" class="btn btn-primary" onclick="switchLeaderboard('weekly')">
                📅 本週排行
            </button>
            <button id="tab-overall" class="btn btn-secondary" onclick="switchLeaderboard('overall')">
                🌟 總排行
            </button>
            <button id="tab-mbti" class="btn btn-secondary" onclick="switchLeaderboard('mbti')">
                🎯 MBTI 分組
            </button>
        </div>

        <!-- 排行榜內容 -->
        <section>
            <div style="background: var(--card-bg); padding: 2rem; border-radius: 1rem; box-shadow: var(--shadow-md);">
                <h2 style="font-size: 1.8rem; margin-bottom: 1.5rem;" id="leaderboard-title">📅 本週貢獻排行</h2>
                
                <div id="leaderboard-container">
                    <div class="simple-hourglass">
                        <span class="hourglass-icon-simple combined">⏳</span>
                        <span class="hourglass-text-simple">載入中...</span>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <!-- 頁尾 -->
    <footer style="text-align: center; padding: 2rem; margin-top: 4rem; color: var(--text-light); border-top: 1px solid var(--border-color);">
        <p>© 2025 MBTI × 桌遊配對</p>
    </footer>

    <script src="js/app.js"></script>
<script src="js/navbar-auth.js"></script>
    <script>
        let currentUser = null;
        let allUserStats = [];
        let allUsers = [];
        let currentLeaderboard = 'weekly';

        // 載入頁面資料
        async function loadPage() {
            try {
                // 獲取當前使用者
                currentUser = GameMBTI.getCurrentUser();
                
                // 載入所有使用者統計資料和使用者資料
                await Promise.all([
                    loadAllStats(),
                    loadAllUsers()
                ]);
                
                // 顯示排行榜
                displayLeaderboard('weekly');
                
            } catch (error) {
                console.error('Error loading page:', error);
            }
        }

        // 載入所有使用者統計資料
        async function loadAllStats() {
            try {
                const response = await fetch('tables/user_stats?limit=1000');
                const result = await response.json();
                allUserStats = result.data || [];
            } catch (error) {
                console.error('Error loading stats:', error);
                allUserStats = [];
            }
        }

        // 載入所有使用者資料
        async function loadAllUsers() {
            try {
                allUsers = await GameMBTI.getAllUsers();
            } catch (error) {
                console.error('Error loading users:', error);
                allUsers = [];
            }
        }

        // 切換排行榜類型
        function switchLeaderboard(type) {
            currentLeaderboard = type;
            
            // 更新按鈕樣式
            document.getElementById('tab-weekly').className = type === 'weekly' ? 'btn btn-primary' : 'btn btn-secondary';
            document.getElementById('tab-overall').className = type === 'overall' ? 'btn btn-primary' : 'btn btn-secondary';
            document.getElementById('tab-mbti').className = type === 'mbti' ? 'btn btn-primary' : 'btn btn-secondary';
            
            // 顯示對應排行榜
            displayLeaderboard(type);
        }

        // 顯示排行榜
        function displayLeaderboard(type) {
            const container = document.getElementById('leaderboard-container');
            const titleEl = document.getElementById('leaderboard-title');
            
            if (type === 'weekly') {
                titleEl.textContent = '📅 本週貢獻排行';
                displayWeeklyLeaderboard(container);
            } else if (type === 'overall') {
                titleEl.textContent = '🌟 總貢獻排行';
                displayOverallLeaderboard(container);
            } else if (type === 'mbti') {
                titleEl.textContent = '🎯 MBTI 分組排行';
                displayMBTILeaderboard(container);
            }
        }

        // 本週排行榜
        function displayWeeklyLeaderboard(container) {
            // 計算本週起始時間（週一 00:00）
            const now = new Date();
            const dayOfWeek = now.getDay();
            const daysToMonday = dayOfWeek === 0 ? 6 : dayOfWeek - 1;
            const monday = new Date(now);
            monday.setDate(now.getDate() - daysToMonday);
            monday.setHours(0, 0, 0, 0);
            const weekStart = monday.getTime();
            
            // 篩選本週有活動的使用者
            const weeklyStats = allUserStats
                .filter(stat => stat.updated_at >= weekStart)
                .map(stat => {
                    const user = allUsers.find(u => u.id === stat.user_id);
                    return {
                        ...stat,
                        username: user ? user.username : '未知使用者',
                        mbti_type: user ? user.mbti_type : 'N/A'
                    };
                })
                .sort((a, b) => b.total_xp - a.total_xp)
                .slice(0, 50);
            
            renderLeaderboardList(container, weeklyStats, 'weekly');
        }

        // 總排行榜
        function displayOverallLeaderboard(container) {
            const overallStats = allUserStats
                .map(stat => {
                    const user = allUsers.find(u => u.id === stat.user_id);
                    return {
                        ...stat,
                        username: user ? user.username : '未知使用者',
                        mbti_type: user ? user.mbti_type : 'N/A'
                    };
                })
                .sort((a, b) => b.total_xp - a.total_xp)
                .slice(0, 100);
            
            renderLeaderboardList(container, overallStats, 'overall');
        }

        // MBTI 分組排行榜
        function displayMBTILeaderboard(container) {
            // 按 MBTI 分組
            const mbtiGroups = {};
            
            allUserStats.forEach(stat => {
                const user = allUsers.find(u => u.id === stat.user_id);
                if (!user) return;
                
                if (!mbtiGroups[user.mbti_type]) {
                    mbtiGroups[user.mbti_type] = [];
                }
                
                mbtiGroups[user.mbti_type].push({
                    ...stat,
                    username: user.username,
                    mbti_type: user.mbti_type
                });
            });
            
            // 渲染各 MBTI 前三名
            let html = '<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">';
            
            Object.keys(GameMBTI.MBTI_TYPES).forEach(mbtiType => {
                const members = mbtiGroups[mbtiType] || [];
                const topThree = members.sort((a, b) => b.total_xp - a.total_xp).slice(0, 3);
                const mbtiInfo = GameMBTI.MBTI_TYPES[mbtiType];
                
                html += `
                    <div style="background: var(--bg-color); padding: 1.5rem; border-radius: 0.75rem; border: 2px solid var(--border-color);">
                        <div style="margin-bottom: 1rem;">
                            <div style="display: inline-block; background: ${mbtiInfo.color}; color: white; padding: 0.5rem 1rem; border-radius: 0.5rem; font-weight: 600; margin-bottom: 0.5rem;">
                                ${mbtiType}
                            </div>
                            <div style="color: var(--text-light); font-size: 0.9rem;">${mbtiInfo.name}</div>
                        </div>
                        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                            ${topThree.length > 0 ? topThree.map((member, index) => `
                                <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.5rem; background: white; border-radius: 0.5rem;">
                                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                                        <span style="font-weight: bold; color: ${index === 0 ? '#fbbf24' : index === 1 ? '#9ca3af' : '#d97706'};">
                                            ${index === 0 ? '🥇' : index === 1 ? '🥈' : '🥉'}
                                        </span>
                                        <span>${member.username}</span>
                                    </div>
                                    <span class="level-badge" style="font-size: 0.85rem; padding: 0.25rem 0.75rem;">Lv.${member.level}</span>
                                </div>
                            `).join('') : '<p style="color: var(--text-light); font-size: 0.9rem; text-align: center;">尚無資料</p>'}
                        </div>
                    </div>
                `;
            });
            
            html += '</div>';
            container.innerHTML = html;
        }

        // 渲染排行榜列表
        function renderLeaderboardList(container, stats, type) {
            if (stats.length === 0) {
                container.innerHTML = '<p style="color: var(--text-light); text-align: center; padding: 2rem;">目前還沒有排行資料</p>';
                return;
            }
            
            let html = '<div style="display: flex; flex-direction: column; gap: 1rem;">';
            
            stats.forEach((stat, index) => {
                const rank = index + 1;
                const isCurrentUser = currentUser && stat.user_id === currentUser.id;
                const rankColor = rank === 1 ? '#fbbf24' : rank === 2 ? '#9ca3af' : rank === 3 ? '#d97706' : 'var(--text-light)';
                const rankIcon = rank === 1 ? '🥇' : rank === 2 ? '🥈' : rank === 3 ? '🥉' : `#${rank}`;
                const mbtiInfo = GameMBTI.MBTI_TYPES[stat.mbti_type] || { name: 'N/A', color: 'linear-gradient(135deg, #667eea, #764ba2)' };
                
                html += `
                    <div style="background: ${isCurrentUser ? '#fef3c7' : 'var(--bg-color)'}; padding: 1.5rem; border-radius: 0.75rem; border: 2px solid ${isCurrentUser ? '#f59e0b' : 'var(--border-color)'}; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;">
                        <div style="display: flex; align-items: center; gap: 1rem; flex: 1; min-width: 200px;">
                            <div style="font-size: 2rem; font-weight: bold; color: ${rankColor}; min-width: 60px; text-align: center;">
                                ${rankIcon}
                            </div>
                            <div style="flex: 1;">
                                <div style="font-size: 1.2rem; font-weight: 600; margin-bottom: 0.25rem;">
                                    ${stat.username}
                                    ${isCurrentUser ? '<span style="color: #f59e0b; font-size: 0.9rem; margin-left: 0.5rem;">(你)</span>' : ''}
                                </div>
                                <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
                                    <span style="background: ${mbtiInfo.color}; color: white; padding: 0.25rem 0.75rem; border-radius: 1rem; font-size: 0.85rem; font-weight: 600;">
                                        ${stat.mbti_type}
                                    </span>
                                    <span class="level-badge" style="font-size: 0.85rem; padding: 0.25rem 0.75rem;">
                                        Lv.${stat.level}
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div style="display: flex; gap: 2rem; align-items: center;">
                            <div style="text-align: center;">
                                <div style="font-size: 1.5rem; font-weight: bold; color: var(--primary-color);">
                                    ${stat.total_xp.toLocaleString()}
                                </div>
                                <div style="color: var(--text-light); font-size: 0.85rem;">總 XP</div>
                            </div>
                            <div style="text-align: center;">
                                <div style="font-size: 1.5rem; font-weight: bold; color: var(--secondary-color);">
                                    ${stat.games_added || 0}
                                </div>
                                <div style="color: var(--text-light); font-size: 0.85rem;">遊戲數</div>
                            </div>
                            <div style="text-align: center;">
                                <div style="font-size: 1.5rem; font-weight: bold; color: var(--accent-color);">
                                    ${stat.votes_count || 0}
                                </div>
                                <div style="color: var(--text-light); font-size: 0.85rem;">投票數</div>
                            </div>
                        </div>
                    </div>
                `;
            });
            
            html += '</div>';
            container.innerHTML = html;
        }

        // 初始化
        document.addEventListener('DOMContentLoaded', loadPage);
    </script>
</body>
</html>
