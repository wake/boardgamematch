<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>資料遷移工具 - MBTI × 桌遊配對</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; padding: 2rem; }
    h1 { color: #38bdf8; font-size: 1.8rem; margin-bottom: 0.5rem; }
    .subtitle { color: #94a3b8; margin-bottom: 2rem; font-size: 0.9rem; }
    .card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem; }
    .card h2 { color: #f1f5f9; font-size: 1.1rem; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
    label { display: block; color: #94a3b8; font-size: 0.85rem; margin-bottom: 0.4rem; margin-top: 0.8rem; }
    input[type="text"], input[type="url"] {
      width: 100%; padding: 0.6rem 0.8rem; background: #0f172a; border: 1px solid #475569;
      border-radius: 8px; color: #e2e8f0; font-size: 0.9rem; outline: none;
    }
    input:focus { border-color: #38bdf8; }
    .btn { padding: 0.6rem 1.2rem; border-radius: 8px; border: none; cursor: pointer; font-size: 0.9rem; font-weight: 600; transition: all 0.2s; }
    .btn-primary { background: #0ea5e9; color: white; }
    .btn-primary:hover { background: #38bdf8; }
    .btn-danger { background: #ef4444; color: white; }
    .btn-danger:hover { background: #f87171; }
    .btn-success { background: #10b981; color: white; }
    .btn-success:hover { background: #34d399; }
    .btn-warning { background: #f59e0b; color: #0f172a; }
    .btn-warning:hover { background: #fbbf24; }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-group { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem; }
    .log-box {
      background: #0a1628; border: 1px solid #1e3a5f; border-radius: 8px;
      padding: 1rem; height: 320px; overflow-y: auto; font-family: 'Courier New', monospace;
      font-size: 0.8rem; line-height: 1.6; margin-top: 1rem;
    }
    .log-ok { color: #34d399; }
    .log-err { color: #f87171; }
    .log-info { color: #60a5fa; }
    .log-warn { color: #fbbf24; }
    .log-dim { color: #475569; }
    .progress-bar { background: #1e3a5f; border-radius: 99px; height: 8px; overflow: hidden; margin-top: 0.5rem; }
    .progress-fill { height: 100%; background: linear-gradient(90deg, #0ea5e9, #38bdf8); transition: width 0.3s; border-radius: 99px; }
    .status-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 0.75rem; margin-top: 1rem; }
    .status-item { background: #0f172a; border: 1px solid #334155; border-radius: 8px; padding: 0.75rem; text-align: center; }
    .status-item .count { font-size: 1.5rem; font-weight: 700; color: #38bdf8; }
    .status-item .label { font-size: 0.75rem; color: #94a3b8; margin-top: 0.25rem; }
    .status-item.done { border-color: #10b981; }
    .status-item.done .count { color: #34d399; }
    .status-item.error { border-color: #ef4444; }
    .status-item.error .count { color: #f87171; }
    .tag { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 99px; font-size: 0.75rem; font-weight: 600; margin-right: 0.3rem; }
    .tag-blue { background: #1e3a5f; color: #60a5fa; }
    .tag-green { background: #14532d; color: #86efac; }
    .tag-red { background: #450a0a; color: #fca5a5; }
    .warning-box { background: #451a03; border: 1px solid #d97706; border-radius: 8px; padding: 1rem; margin-top: 1rem; }
    .warning-box p { color: #fcd34d; font-size: 0.85rem; line-height: 1.6; }
    .steps { counter-reset: step; }
    .step { display: flex; gap: 1rem; margin-bottom: 1rem; }
    .step-num { width: 28px; height: 28px; background: #0ea5e9; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; flex-shrink: 0; margin-top: 0.1rem; }
    .step-content { flex: 1; }
    .step-content h3 { color: #f1f5f9; font-size: 0.9rem; margin-bottom: 0.3rem; }
    .step-content p { color: #94a3b8; font-size: 0.82rem; line-height: 1.5; }
    code { background: #0f172a; padding: 0.15rem 0.4rem; border-radius: 4px; font-family: monospace; font-size: 0.82rem; color: #7dd3fc; }
  </style>
</head>
<body>

<h1>🚀 資料遷移工具</h1>
<p class="subtitle">將 Genspark 資料庫的資料完整遷移到 Cloudflare D1</p>

<!-- 步驟說明 -->
<div class="card">
  <h2>📋 操作步驟（先做這個！）</h2>
  <div class="steps">
    <div class="step">
      <div class="step-num">1</div>
      <div class="step-content">
        <h3>在 Cloudflare D1 建立資料表</h3>
        <p>前往 <a href="https://dash.cloudflare.com" target="_blank" style="color:#38bdf8">Cloudflare Dashboard</a> → D1 → <code>mbti-board-game-matcher-db</code> → Console，貼上 <code>cloudflare/schema.sql</code> 的內容執行。</p>
      </div>
    </div>
    <div class="step">
      <div class="step-num">2</div>
      <div class="step-content">
        <h3>部署最新 Worker</h3>
        <p>前往 Workers & Pages → <code>mbti-board-game-matcher</code> → 編輯程式碼，貼上最新的 <code>cloudflare/worker.js</code> 並部署。確認 Worker 綁定了 D1 資料庫（Settings → Bindings → D1 Database binding = <code>DB</code>）。</p>
      </div>
    </div>
    <div class="step">
      <div class="step-num">3</div>
      <div class="step-content">
        <h3>填入下方設定，執行遷移</h3>
        <p>填入來源（Genspark）和目標（你的 CF Worker）網址，然後依序點擊各資料表的遷移按鈕。</p>
      </div>
    </div>
    <div class="step">
      <div class="step-num">4</div>
      <div class="step-content">
        <h3>更新 Cloudflare Worker Route</h3>
        <p>遷移完成後，前往 <code>boardgamematch.com.tw</code> → Workers Routes，把現有路由 <code>boardgamematch.com.tw/tables/*</code> 的 Worker 改指向包含 D1 的那個 Worker（非 proxy-worker），或確認已綁定 D1。</p>
      </div>
    </div>
  </div>
</div>

<!-- 設定 -->
<div class="card">
  <h2>⚙️ 來源與目標設定</h2>
  <label>來源 API（Genspark 原始資料庫）</label>
  <input type="url" id="src-api" value="https://ba3d09ec-fb6a-466f-83dd-38bfd12bd387.vip.gensparksite.com" placeholder="https://ba3d09ec-fb6a-466f-83dd-38bfd12bd387.vip.gensparksite.com">
  <label>目標 API（你的 Cloudflare Worker / Pages）</label>
  <input type="url" id="dst-api" value="https://mbti-board-game-matcher.pages.dev" placeholder="https://mbti-board-game-matcher.pages.dev">
  <p style="color:#fbbf24; font-size:0.8rem; margin-top:0.5rem;">💡 來源直接使用 Genspark 原始網址（CORS 已允許同源請求）；目標填入你的 CF Pages 或 Worker 網址。</p>
</div>

<!-- 遷移控制 -->
<div class="card">
  <h2>🎯 遷移控制</h2>
  
  <div class="warning-box">
    <p>⚠️ <strong>重要：</strong>遷移前請確認目標 Worker 的 D1 資料表已建立完成（步驟1）。若重複執行，相同 ID 的資料會被覆蓋（INSERT OR REPLACE）。</p>
  </div>

  <div class="btn-group">
    <button class="btn btn-success" id="btn-migrate-all" onclick="migrateAll()">🚀 一鍵全部遷移</button>
    <button class="btn btn-primary" id="btn-test" onclick="testConnections()">🔌 測試連線</button>
    <button class="btn btn-warning" id="btn-verify" onclick="verifyCounts()">🔍 比對筆數</button>
    <button class="btn btn-danger" id="btn-clear-log" onclick="clearLog()">🗑️ 清除記錄</button>
  </div>

  <div style="margin-top:1.5rem">
    <h3 style="color:#94a3b8; font-size:0.85rem; margin-bottom:0.75rem; text-transform: uppercase; letter-spacing: 0.05em;">個別表遷移</h3>
    <div class="btn-group" id="table-btns">
      <!-- 動態生成 -->
    </div>
  </div>

  <div class="progress-bar" style="margin-top:1rem">
    <div class="progress-fill" id="progress-fill" style="width:0%"></div>
  </div>
  <div id="progress-text" style="color:#94a3b8; font-size:0.8rem; margin-top:0.4rem; text-align:center;">等待開始...</div>

  <div class="log-box" id="log"></div>
</div>

<!-- 遷移狀態 -->
<div class="card">
  <h2>📊 遷移狀態</h2>
  <div class="status-grid" id="status-grid">
    <!-- 動態生成 -->
  </div>
</div>

<script>
// ── 設定 ──────────────────────────────────────────────
const TABLES_TO_MIGRATE = [
  { name: 'users',                  priority: 1 },
  { name: 'user_stats',             priority: 2 },
  { name: 'achievements',           priority: 3 },
  { name: 'admin_whitelist',        priority: 4 },
  { name: 'tester_whitelist',       priority: 4 },
  { name: 'influencer_whitelist',   priority: 4 },
  { name: 'game_database',          priority: 5 },
  { name: 'game_aliases',           priority: 6 },
  { name: 'game_votes',             priority: 7 },
  { name: 'game_collections',       priority: 8 },
  { name: 'collection_game_stats',  priority: 9 },
  { name: 'user_collections',       priority: 9 },
  { name: 'user_collection_votes',  priority: 10 },
  { name: 'publisher_badge_series', priority: 10 },
  { name: 'quiz_collections',       priority: 11 },
  { name: 'quiz_questions',         priority: 11 },
  { name: 'quiz_attempts',          priority: 12 },
  { name: 'daily_quests',           priority: 13 },
  { name: 'limited_events',         priority: 14 },
  { name: 'event_progress',         priority: 15 },
  { name: 'site_stats',             priority: 16 },
];

const migrateStatus = {};
TABLES_TO_MIGRATE.forEach(t => {
  migrateStatus[t.name] = { srcCount: '?', dstCount: '?', migrated: 0, status: 'pending' };
});

let isRunning = false;

// ── DOM 初始化 ────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  renderTableBtns();
  renderStatusGrid();
});

function renderTableBtns() {
  const container = document.getElementById('table-btns');
  container.innerHTML = TABLES_TO_MIGRATE.map(t => `
    <button class="btn btn-primary" id="btn-${t.name}" onclick="migrateTable('${t.name}')" style="font-size:0.78rem; padding:0.4rem 0.8rem;">${t.name}</button>
  `).join('');
}

function renderStatusGrid() {
  const grid = document.getElementById('status-grid');
  grid.innerHTML = TABLES_TO_MIGRATE.map(t => `
    <div class="status-item" id="status-${t.name}">
      <div class="count" id="count-${t.name}">-</div>
      <div class="label">${t.name}</div>
    </div>
  `).join('');
}

// ── 工具函式 ──────────────────────────────────────────
function log(msg, type = 'info') {
  const box = document.getElementById('log');
  const time = new Date().toTimeString().slice(0, 8);
  const line = document.createElement('div');
  line.className = `log-${type}`;
  line.textContent = `[${time}] ${msg}`;
  box.appendChild(line);
  box.scrollTop = box.scrollHeight;
}

function clearLog() {
  document.getElementById('log').innerHTML = '';
}

function setProgress(done, total, label) {
  const pct = total > 0 ? Math.round(done / total * 100) : 0;
  document.getElementById('progress-fill').style.width = pct + '%';
  document.getElementById('progress-text').textContent = label || `${done} / ${total} (${pct}%)`;
}

function getSrc() { return document.getElementById('src-api').value.replace(/\/$/, ''); }
function getDst() { return document.getElementById('dst-api').value.replace(/\/$/, ''); }

function updateStatusCard(tableName, count, state) {
  const card = document.getElementById(`status-${tableName}`);
  const countEl = document.getElementById(`count-${tableName}`);
  if (!card || !countEl) return;
  card.className = 'status-item ' + (state === 'done' ? 'done' : state === 'error' ? 'error' : '');
  countEl.textContent = count;
}

// ── 分頁抓取所有資料 ──────────────────────────────────
async function fetchAllFromSrc(tableName) {
  const src = getSrc();
  const allData = [];
  let page = 1;
  let total = 0;
  
  do {
    const url = `${src}/tables/${tableName}?limit=100&page=${page}`;
    const res = await fetch(url);
    if (!res.ok) {
      log(`  ❌ 抓取 ${tableName} 第 ${page} 頁失敗: HTTP ${res.status}`, 'err');
      break;
    }
    const json = await res.json();
    const rows = json.data || [];
    total = json.total || rows.length;
    allData.push(...rows);
    log(`  ↓ ${tableName} 第 ${page} 頁: ${rows.length} 筆（累計 ${allData.length}/${total}）`, 'dim');
    page++;
  } while (allData.length < total && page <= 200);
  
  return allData;
}

// ── 過濾 Genspark 系統欄位 ────────────────────────────
const GS_SYSTEM_FIELDS = new Set([
  'gs_project_id', 'gs_table_name', 'gs_created_at', 'gs_updated_at', 'deleted',
  '_rid', '_id', '__rid', '__id'  // Genspark 隱藏系統欄位
]);

function cleanRow(row) {
  const cleaned = {};
  for (const [k, v] of Object.entries(row)) {
    // 跳過系統欄位（完整名稱 或 gs_ / __ 開頭）
    if (GS_SYSTEM_FIELDS.has(k)) continue;
    if (k.startsWith('gs_') || k.startsWith('__')) continue;

    // 物件/陣列 → 序列化成 JSON 字串（D1 text 欄位只接受純量）
    if (v !== null && typeof v === 'object') {
      cleaned[k] = JSON.stringify(v);
    } else {
      cleaned[k] = v;
    }
  }
  return cleaned;
}

// ── 批次寫入目標 ──────────────────────────────────────
async function writeAllToDst(tableName, rows) {
  const dst = getDst();
  if (!dst) { log('❌ 請先填入目標 API 網址！', 'err'); return 0; }
  
  let ok = 0, fail = 0;
  const BATCH = 3; // 同時寫 3 筆，避免過載
  
  for (let i = 0; i < rows.length; i += BATCH) {
    const batch = rows.slice(i, i + BATCH);
    await Promise.all(batch.map(async (row) => {
      const cleanedRow = cleanRow(row); // 過濾掉 gs_* 系統欄位
      try {
        // 先嘗試 PUT（若記錄已存在則更新）
        const r = await fetch(`${dst}/tables/${tableName}/${cleanedRow.id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(cleanedRow)
        });
        if (r.ok) {
          ok++;
        } else if (r.status === 404 || r.status === 405) {
          // 目標沒有此筆資料，改用 POST 新增
          const r2 = await fetch(`${dst}/tables/${tableName}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(cleanedRow)
          });
          if (r2.ok) {
            ok++;
          } else {
            fail++;
            const errText = await r2.text().catch(() => r2.status);
            log(`  ⚠️ POST ${tableName}/${cleanedRow.id?.slice(0,8)} 失敗: ${r2.status} ${errText.slice(0,100)}`, 'warn');
          }
        } else {
          fail++;
          const errText = await r.text().catch(() => r.status);
          log(`  ⚠️ PUT ${tableName}/${cleanedRow.id?.slice(0,8)} 失敗: ${r.status} ${errText.slice(0,100)}`, 'warn');
        }
      } catch (e) {
        fail++;
        log(`  ⚠️ 寫入 ${cleanedRow.id?.slice(0,8)} 例外: ${e.message}`, 'warn');
      }
    }));
    
    // 每 BATCH 筆更新一次進度
    setProgress(ok + fail, rows.length, `${tableName}: 寫入 ${ok + fail}/${rows.length}...`);
    await new Promise(r => setTimeout(r, 100)); // 小延遲避免打爆
  }
  
  return ok;
}

// ── 遷移單一資料表 ────────────────────────────────────
async function migrateTable(tableName, silent = false) {
  if (!silent) {
    if (isRunning) { log('⚠️ 正在執行中，請等待...', 'warn'); return 0; }
    if (!getDst()) { log('❌ 請先填入目標 CF Worker API 網址！', 'err'); return 0; }
  }
  
  if (!silent) isRunning = true;
  document.getElementById(`btn-${tableName}`)?.setAttribute('disabled', 'true');
  
  log(`\n📦 開始遷移: ${tableName}`, 'info');
  updateStatusCard(tableName, '...', '');
  
  try {
    // 1. 抓來源資料
    const rows = await fetchAllFromSrc(tableName);
    log(`  ✅ 來源共 ${rows.length} 筆`, 'ok');
    updateStatusCard(tableName, rows.length, '');
    
    if (rows.length === 0) {
      log(`  ℹ️ ${tableName} 無資料，跳過`, 'dim');
      updateStatusCard(tableName, '0', 'done');
      if (!silent) isRunning = false;
      document.getElementById(`btn-${tableName}`)?.removeAttribute('disabled');
      return 0;
    }
    
    // 2. 寫入目標
    const written = await writeAllToDst(tableName, rows);
    log(`  ✅ 成功寫入 ${written}/${rows.length} 筆到 CF D1`, 'ok');
    updateStatusCard(tableName, `${written}/${rows.length}`, written === rows.length ? 'done' : 'error');
    
    if (!silent) isRunning = false;
    document.getElementById(`btn-${tableName}`)?.removeAttribute('disabled');
    return written;
    
  } catch (e) {
    log(`  ❌ ${tableName} 遷移失敗: ${e.message}`, 'err');
    updateStatusCard(tableName, 'ERR', 'error');
    if (!silent) isRunning = false;
    document.getElementById(`btn-${tableName}`)?.removeAttribute('disabled');
    return 0;
  }
}

// ── 一鍵全部遷移 ──────────────────────────────────────
async function migrateAll() {
  if (isRunning) { log('⚠️ 正在執行中，請等待...', 'warn'); return; }
  if (!getDst()) { log('❌ 請先填入目標 CF Worker API 網址！', 'err'); return; }
  
  isRunning = true;
  document.getElementById('btn-migrate-all').disabled = true;
  log('\n🚀 開始全部遷移...', 'info');
  log(`  來源: ${getSrc()}`, 'dim');
  log(`  目標: ${getDst()}`, 'dim');
  
  // 按優先順序排列
  const sorted = [...TABLES_TO_MIGRATE].sort((a, b) => a.priority - b.priority);
  let totalDone = 0;
  
  for (let i = 0; i < sorted.length; i++) {
    const t = sorted[i];
    setProgress(i, sorted.length, `整體進度: ${i}/${sorted.length}（當前: ${t.name}）`);
    await migrateTable(t.name, true);
    totalDone++;
    await new Promise(r => setTimeout(r, 200)); // 每表間隔 200ms
  }
  
  setProgress(sorted.length, sorted.length, `完成！共遷移 ${sorted.length} 個資料表`);
  log('\n🎉 全部遷移完成！請點「比對筆數」確認。', 'ok');
  
  isRunning = false;
  document.getElementById('btn-migrate-all').disabled = false;
}

// ── 測試連線 ──────────────────────────────────────────
async function testConnections() {
  log('\n🔌 測試來源與目標連線...', 'info');
  const src = getSrc();
  const dst = getDst();
  
  if (!dst) { log('❌ 請先填入目標 API 網址！', 'err'); return; }
  
  try {
    const srcRes = await fetch(`${src}/tables/users?limit=1&page=1`);
    if (srcRes.ok) {
      const d = await srcRes.json();
      log(`✅ 來源 (${src}) 連線成功！users 共 ${d.total} 筆`, 'ok');
    } else {
      log(`❌ 來源連線失敗: HTTP ${srcRes.status}`, 'err');
    }
  } catch (e) {
    log(`❌ 來源連線錯誤: ${e.message}`, 'err');
  }
  
  try {
    const dstRes = await fetch(`${dst}/tables/users?limit=1&page=1`);
    if (dstRes.ok) {
      const d = await dstRes.json();
      log(`✅ 目標 (${dst}) 連線成功！users 現有 ${d.total} 筆`, 'ok');
    } else {
      log(`❌ 目標連線失敗: HTTP ${dstRes.status}`, 'err');
    }
  } catch (e) {
    log(`❌ 目標連線錯誤: ${e.message}（可能是 CORS 問題）`, 'err');
  }
}

// ── 比對來源與目標筆數 ────────────────────────────────
async function verifyCounts() {
  if (isRunning) { log('⚠️ 正在執行中，請等待...', 'warn'); return; }
  if (!getDst()) { log('❌ 請先填入目標 CF Worker API 網址！', 'err'); return; }
  
  isRunning = true;
  log('\n🔍 開始比對筆數...', 'info');
  
  for (const t of TABLES_TO_MIGRATE) {
    try {
      const [srcRes, dstRes] = await Promise.all([
        fetch(`${getSrc()}/tables/${t.name}?limit=1&page=1`).then(r => r.json()).catch(() => ({ total: '?' })),
        fetch(`${getDst()}/tables/${t.name}?limit=1&page=1`).then(r => r.json()).catch(() => ({ total: '?' }))
      ]);
      
      const srcCnt = srcRes.total ?? '?';
      const dstCnt = dstRes.total ?? '?';
      const match = srcCnt === dstCnt;
      
      log(`  ${match ? '✅' : '⚠️'} ${t.name.padEnd(30)} 來源: ${String(srcCnt).padStart(6)} | 目標: ${String(dstCnt).padStart(6)} ${!match ? '← 不一致！' : ''}`, match ? 'ok' : 'warn');
      updateStatusCard(t.name, `${dstCnt}/${srcCnt}`, match ? 'done' : 'error');
    } catch (e) {
      log(`  ❌ ${t.name}: ${e.message}`, 'err');
    }
  }
  
  log('\n比對完成！', 'info');
  isRunning = false;
}
</script>

</body>
</html>
