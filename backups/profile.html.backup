<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>我的檔案 - MBTI × 桌遊配對</title>
    <link rel="stylesheet" href="css/styles.css">
    <link rel="stylesheet" href="css/gamification.css">
    <link rel="stylesheet" href="css/hourglass-simple.css">
</head>
<body>
    <!-- 導覽列 -->
    <nav class="navbar">
        <div class="navbar-container">
            <a href="index.html" class="navbar-logo">
                <span>🎲</span>
                MBTI × 桌遊配對
            </a>
            <ul class="navbar-menu">
                <li><a href="index.html">回到首頁</a></li>
                <li><a href="explore.html">玩家數據</a></li>
                <li><a href="recommend.html">桌遊探索</a></li>
                <li><a href="leaderboard.html">貢獻排行</a></li>
                <li><a href="profile.html" class="active">我的檔案</a></li>
            </ul>
        </div>
    </nav>

    <!-- 主要內容 -->
    <div class="container">
        <!-- 載入中狀態 -->
        <div id="loading-state" style="text-align: center; padding: 4rem 2rem;">
            <div class="simple-hourglass large">
                <span class="hourglass-icon-simple combined">⏳</span>
                <span class="hourglass-text-simple">正在載入你的檔案資料</span>
            </div>
        </div>
        
        <!-- 未登入狀態 -->
        <div id="not-logged-in" style="display: none;">
            <div class="empty-state" style="padding: 4rem 2rem;">
                <div class="empty-state-icon">🔒</div>
                <h2 class="empty-state-text">需要登入才能查看檔案</h2>
                <p style="color: var(--text-light); margin-bottom: 2rem;">
                    請先使用 Google 帳號登入，然後分享你的桌遊喜好
                </p>
                <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                    <a href="index.html" class="btn btn-primary" style="font-size: 1.1rem;">
                        🔑 前往登入
                    </a>
                </div>
            </div>
        </div>

        <!-- 已登入狀態 -->
        <div id="logged-in" style="display: none;">
            <!-- 使用者資訊卡片 -->
            <section style="margin-bottom: 3rem;">
                <div style="background: var(--card-bg); padding: 2rem; border-radius: 1rem; box-shadow: var(--shadow-lg); position: relative;">
                    <div style="position: absolute; top: 0; left: 0; right: 0; height: 6px; border-radius: 1rem 1rem 0 0;" id="profile-gradient"></div>
                    
                    <div style="display: flex; justify-content: space-between; align-items: start; flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem;">
                        <div style="flex: 1; min-width: 250px;">
                            <div style="font-size: 3rem; margin-bottom: 1rem;">👤</div>
                            <h1 style="font-size: 2rem; margin-bottom: 0.5rem;" id="profile-username">-</h1>
                            <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; margin-bottom: 0.5rem;">
                                <span style="background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%); color: white; padding: 0.5rem 1rem; border-radius: 2rem; font-weight: 600;" id="profile-mbti">INTJ</span>
                                <span style="color: var(--text-light);" id="profile-mbti-name">建築師</span>
                                <span class="level-badge" id="profile-level-badge">Lv. 1</span>
                            </div>
                            <p style="color: var(--text-light); margin-bottom: 1rem;" id="profile-created-at">加入於 -</p>
                            
                            <!-- XP 進度條 -->
                            <div style="margin-top: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.9rem;">
                                    <span style="color: var(--text-light);">經驗值</span>
                                    <span style="color: var(--primary-color); font-weight: 600;" id="profile-xp-text">0 / 100 XP</span>
                                </div>
                                <div style="background: var(--border-color); height: 8px; border-radius: 1rem; overflow: hidden;">
                                    <div id="profile-xp-bar" style="background: linear-gradient(90deg, var(--primary-color), var(--secondary-color)); height: 100%; width: 0%; transition: width 0.5s ease;"></div>
                                </div>
                            </div>
                        </div>
                        
                        <div style="display: flex; gap: 0.5rem;">
                            <a href="edit-games-drag.html" class="btn btn-secondary">✏️ 編輯桌遊</a>
                            <button class="btn btn-secondary" onclick="deleteProfile()" style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); color: white; border: none;">
                                🗑️ 刪除
                            </button>
                        </div>
                    </div>

                    <!-- 統計數據 -->
                    <div style="padding-top: 1.5rem; border-top: 1px solid var(--border-color);">
                        <!-- 同類型重疊度 -->
                        <div style="margin-bottom: 1.5rem;">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                                <span style="color: var(--text-color); font-weight: 600; font-size: 0.95rem; display: flex; align-items: center; gap: 0.3rem;">
                                    🎯 同類型重疊度
                                    <span class="info-tooltip" title="計算公式：雙向重疊度 = (喜歡的重疊 + 不喜歡的重疊) ÷ (Top 20 喜歡 + Top 20 不喜歡) × 100%&#10;&#10;語意：衡量你與同類型玩家的品味相似度&#10;&#10;範例：&#10;• 同類型 Top 20 喜歡：A, B, C...（20款），你也喜歡其中 15 款 ✅&#10;• 同類型 Top 20 不喜歡：X, Y, Z...（20款），你也不喜歡其中 10 款 ✅&#10;• 重疊度 = (15 + 10) ÷ 40 = 62.5%&#10;&#10;注意：品味不同不算重疊（例如：大家喜歡但你不喜歡）">ⓘ</span>
                                </span>
                                <span style="color: var(--primary-color); font-weight: 700; font-size: 1.2rem;" id="overlap-percentage">-</span>
                            </div>
                            <div style="background: var(--border-color); height: 12px; border-radius: 1rem; overflow: hidden; position: relative;">
                                <div id="overlap-bar" style="background: linear-gradient(90deg, var(--primary-color), var(--secondary-color)); height: 100%; width: 0%; transition: width 0.8s ease;"></div>
                            </div>
                            <div style="margin-top: 0.5rem; color: var(--text-light); font-size: 0.85rem;" id="overlap-description">載入中...</div>
                        </div>
                        
                        <!-- 趨向性分析 -->
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                            <div style="text-align: center; padding: 1rem; background: var(--bg-color); border-radius: 0.75rem;">
                                <div style="font-size: 1.8rem; font-weight: bold; color: var(--primary-color);" id="profile-liked-count">-</div>
                                <div style="color: var(--text-light); font-size: 0.85rem; display: flex; align-items: center; justify-content: center; gap: 0.3rem;">
                                    已評價遊戲
                                    <span class="info-tooltip" title="計算公式：已評價遊戲 / 資料庫總遊戲數&#10;&#10;已評價遊戲 = 喜歡 + 不喜歡（不含待玩清單）&#10;&#10;範例：你喜歡 15 款 + 不喜歡 10 款 = 25 款，資料庫共 500 款，則顯示 25 / 500">ⓘ</span>
                                </div>
                            </div>
                            <div style="text-align: center; padding: 1rem; background: var(--bg-color); border-radius: 0.75rem;">
                                <div style="font-size: 1.8rem; font-weight: bold; color: var(--secondary-color);" id="profile-same-type-count">-</div>
                                <div style="color: var(--text-light); font-size: 0.85rem;">同類型玩家</div>
                            </div>
                        </div>
                        
                        <!-- 趨向性標籤 -->
                        <div style="margin-top: 1rem; text-align: center;">
                            <div id="tendency-badge" style="display: inline-block; padding: 0.5rem 1.5rem; border-radius: 2rem; font-weight: 600; font-size: 0.9rem;">
                                載入中...
                            </div>
                        </div>
                    </div>

                    <!-- 社群連結 -->
                    <div style="padding-top: 1.5rem; border-top: 1px solid var(--border-color); margin-top: 1.5rem;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                            <h3 style="font-size: 1.2rem; margin: 0; color: var(--text-color);">📱 我的社群連結</h3>
                            <button onclick="toggleEditSocialLinks()" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.8rem;">
                                <span id="editSocialLinksBtn">✏️ 編輯</span>
                            </button>
                        </div>
                        
                        <!-- 顯示模式 -->
                        <div id="socialLinksDisplay">
                            <div class="simple-hourglass small">
                                <span class="hourglass-icon-simple combined">⏳</span>
                                <span class="hourglass-text-simple">載入中...</span>
                            </div>
                        </div>
                        
                        <!-- 編輯模式 -->
                        <div id="socialLinksEdit" style="display: none;">
                            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 0.75rem;">
                                <div>
                                    <label style="display: block; margin-bottom: 0.3rem; font-weight: 600; font-size: 0.9rem;">
                                        💬 Discord
                                    </label>
                                    <input type="text" id="input-discord" placeholder="username#1234" 
                                        style="width: 100%; padding: 0.6rem; border: 1px solid var(--border-color); border-radius: 0.5rem; font-size: 0.9rem;">
                                </div>
                                <div>
                                    <label style="display: block; margin-bottom: 0.3rem; font-weight: 600; font-size: 0.9rem;">
                                        📱 LINE
                                    </label>
                                    <input type="text" id="input-line" placeholder="mylineid" 
                                        style="width: 100%; padding: 0.6rem; border: 1px solid var(--border-color); border-radius: 0.5rem; font-size: 0.9rem;">
                                </div>
                                <div>
                                    <label style="display: block; margin-bottom: 0.3rem; font-weight: 600; font-size: 0.9rem;">
                                        📷 Instagram
                                    </label>
                                    <input type="text" id="input-instagram" placeholder="@username" 
                                        style="width: 100%; padding: 0.6rem; border: 1px solid var(--border-color); border-radius: 0.5rem; font-size: 0.9rem;">
                                </div>
                                <div>
                                    <label style="display: block; margin-bottom: 0.3rem; font-weight: 600; font-size: 0.9rem;">
                                        📘 Facebook
                                    </label>
                                    <input type="text" id="input-facebook" placeholder="個人檔案連結" 
                                        style="width: 100%; padding: 0.6rem; border: 1px solid var(--border-color); border-radius: 0.5rem; font-size: 0.9rem;">
                                </div>
                                <div>
                                    <label style="display: block; margin-bottom: 0.3rem; font-weight: 600; font-size: 0.9rem;">
                                        ✈️ Telegram
                                    </label>
                                    <input type="text" id="input-telegram" placeholder="@username" 
                                        style="width: 100%; padding: 0.6rem; border: 1px solid var(--border-color); border-radius: 0.5rem; font-size: 0.9rem;">
                                </div>
                                <div>
                                    <label style="display: block; margin-bottom: 0.3rem; font-weight: 600; font-size: 0.9rem;">
                                        🧵 Threads
                                    </label>
                                    <input type="text" id="input-threads" placeholder="@username" 
                                        style="width: 100%; padding: 0.6rem; border: 1px solid var(--border-color); border-radius: 0.5rem; font-size: 0.9rem;">
                                </div>
                            </div>
                            <div style="display: flex; gap: 0.75rem; margin-top: 1rem;">
                                <button onclick="saveSocialLinks()" class="btn btn-primary" style="flex: 1; font-size: 0.9rem; padding: 0.6rem;">
                                    💾 儲存連結
                                </button>
                                <button onclick="toggleEditSocialLinks()" class="btn btn-secondary" style="flex: 1; font-size: 0.9rem; padding: 0.6rem;">
                                    ❌ 取消
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 遊戲列表 -->
            <section style="margin-bottom: 3rem;">
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
                    <!-- 喜歡的桌遊 -->
                    <div class="game-list">
                        <h2 class="game-list-title">😍 我喜歡的桌遊</h2>
                        <div style="flex: 1; overflow-y: auto; margin-bottom: 1rem;">
                            <div id="profile-liked-games">
                                <div class="hourglass-loader small">
                                    <span class="hourglass-icon">⏳</span>
                                    <span class="hourglass-text">載入中...</span>
                                </div>
                            </div>
                        </div>
                        <div id="profile-liked-more" style="text-align: right;"></div>
                    </div>

                    <!-- 不喜歡的桌遊 -->
                    <div class="game-list">
                        <h2 class="game-list-title">😕 我不喜歡的桌遊</h2>
                        <div style="flex: 1; overflow-y: auto; margin-bottom: 1rem;">
                            <div id="profile-disliked-games">
                                <div class="hourglass-loader small">
                                    <span class="hourglass-icon">⏳</span>
                                    <span class="hourglass-text">載入中...</span>
                                </div>
                            </div>
                        </div>
                        <div id="profile-disliked-more" style="text-align: right;"></div>
                    </div>
                    
                    <!-- 待玩清單 -->
                    <div class="game-list">
                        <h2 class="game-list-title">📋 我的待玩清單</h2>
                        <div style="flex: 1; overflow-y: auto; margin-bottom: 1rem;">
                            <div id="profile-wishlist">
                                <div class="hourglass-loader small">
                                    <span class="hourglass-icon">⏳</span>
                                    <span class="hourglass-text">載入中...</span>
                                </div>
                            </div>
                        </div>
                        <div id="profile-wishlist-more" style="text-align: right;"></div>
                    </div>
                </div>
            </section>

            <!-- 推薦區域 -->
            <section style="margin-bottom: 3rem;">
                <div style="background: var(--card-bg); padding: 2rem; border-radius: 1rem; box-shadow: var(--shadow-md);">
                    <h2 style="font-size: 1.8rem; margin-bottom: 1rem;">🎯 給你的推薦</h2>
                    <p style="color: var(--text-light); margin-bottom: 1.5rem;">
                        根據你的 MBTI 類型，以下是同類型玩家最喜歡的桌遊
                    </p>
                    <div id="recommendations" class="game-tags-container">
                        <div class="simple-hourglass">
                            <span class="hourglass-icon-simple combined">⏳</span>
                            <span class="hourglass-text-simple">分析中...</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 探索同類型玩家 -->
            <section style="margin-bottom: 3rem;">
                <div style="background: var(--card-bg); padding: 2rem; border-radius: 1rem; box-shadow: var(--shadow-md);">
                    <h2 style="font-size: 1.8rem; margin: 0 0 1.5rem 0;">👥 發現其他玩家</h2>
                    
                    <!-- 最相似玩家 -->
                    <div style="margin-bottom: 2rem;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                            <h3 style="font-size: 1.3rem; margin: 0; color: var(--primary-color);">
                                💚 最相似的玩家
                                <span style="font-size: 0.85rem; color: var(--text-light); font-weight: normal;">（品味最接近）</span>
                            </h3>
                            <a href="explore.html?sort=similar" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.5rem 1rem;">查看更多 →</a>
                        </div>
                        <div id="most-similar-users" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem;">
                            <div class="simple-hourglass">
                                <span class="hourglass-icon-simple combined">⏳</span>
                                <span class="hourglass-text-simple">載入中...</span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 最不相似玩家 -->
                    <div>
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                            <h3 style="font-size: 1.3rem; margin: 0; color: var(--accent-color);">
                                🎨 最不相似的玩家
                                <span style="font-size: 0.85rem; color: var(--text-light); font-weight: normal;">（品味最獨特）</span>
                            </h3>
                            <a href="explore.html?sort=different" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.5rem 1rem;">查看更多 →</a>
                        </div>
                        <div id="most-different-users" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem;">
                            <div class="simple-hourglass">
                                <span class="hourglass-icon-simple combined">⏳</span>
                                <span class="hourglass-text-simple">載入中...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 徽章牆 -->
            <section>
                <div style="background: var(--card-bg); padding: 2rem; border-radius: 1rem; box-shadow: var(--shadow-md);">
                    <h2 style="font-size: 1.8rem; margin-bottom: 1rem;">🏆 我的成就徽章</h2>
                    <p style="color: var(--text-light); margin-bottom: 1.5rem;">
                        解鎖更多成就，展示你的桌遊品味！
                    </p>
                    <div id="achievements-wall" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem;">
                        <div class="loading">
                            <div class="spinner"></div>
                            <p>載入中...</p>
                        </div>
                    </div>
                </div>
            </section>

        </div>
    </div>

    <!-- 頁尾 -->
    <footer style="text-align: center; padding: 2rem; margin-top: 4rem; color: var(--text-light); border-top: 1px solid var(--border-color);">
        <p>© 2025 MBTI × 桌遊配對</p>
    </footer>

    <script src="js/app.js"></script>
<script src="js/navbar-auth.js"></script>
    <script>
        let currentUser = null;
        let allUsers = [];

        // 載入使用者檔案
        async function loadProfile() {
            console.log('🚀 loadProfile() 開始執行...');
            console.log('📍 步驟 1: 準備檢查 localStorage');
            
            try {
                // 從本地儲存獲取當前使用者 ID
                const localUser = GameMBTI.getCurrentUser();
                console.log('📍 步驟 2: localStorage 檢查完成，結果:', localUser ? '有資料' : '無資料');
                
                if (!localUser) {
                    console.log('❌ 沒有找到 localStorage 中的使用者資料');
                    showNotLoggedIn();
                    return;
                }

                console.log('✅ 找到 localStorage 使用者:', localUser.id, localUser.username);
                console.log('📍 步驟 3: 準備從 API 載入使用者資料...');

                // 從 API 重新載入最新的使用者資料
                currentUser = await GameMBTI.getUserById(localUser.id);
                console.log('📍 步驟 4: API 呼叫完成，結果:', currentUser ? '成功' : '失敗');
                
                // 檢查 API 是否成功返回資料
                if (!currentUser) {
                    console.error('❌ API 無法載入使用者資料，ID:', localUser.id);
                    alert('⚠️ 無法載入使用者資料\n\n可能原因：\n1. 資料庫連線問題\n2. 使用者資料不存在\n3. API 路徑錯誤\n\n請嘗試：\n- 重新整理頁面\n- 前往除錯頁面 (debug-profile.html)\n- 或重新註冊');
                    showNotLoggedIn();
                    return;
                }
                
                console.log('✅ 成功載入使用者資料:', currentUser.username);
                console.log('📍 步驟 5: 更新 localStorage...');
                
                // 更新 localStorage（確保資料同步）
                GameMBTI.setCurrentUser(currentUser);
                console.log('📍 步驟 6: 準備載入所有使用者...');

                // 載入所有使用者（用於統計）
                allUsers = await GameMBTI.getAllUsers();
                console.log('✅ 成功載入所有使用者，總共:', allUsers.length);
                console.log('📍 步驟 7: 準備顯示檔案內容...');
                
                // 顯示檔案內容
                displayProfile();
                
                // 🎯 檢查並解鎖成就（在背景執行，不阻塞頁面載入）
                GameMBTI.checkAndUnlockAchievements(currentUser.id).catch(err => {
                    console.warn('⚠️ 成就檢查失敗（不影響頁面載入）:', err);
                });
                
                await displayUserStats(); // 載入並顯示 XP、等級、徽章
                displayGames();
                displayRecommendations();
                displaySimilarAndDifferentUsers();
                
                console.log('✅ Profile 頁面載入完成');
                
            } catch (error) {
                console.error('❌ Error loading profile:', error);
                alert('⚠️ 載入檔案時發生錯誤\n\n錯誤訊息: ' + error.message + '\n\n請開啟瀏覽器主控台(F12)查看詳細資訊，或前往除錯頁面 (debug-profile.html)');
                showNotLoggedIn();
            }
        }

        // 顯示未登入狀態
        function showNotLoggedIn() {
            document.getElementById('loading-state').style.display = 'none';
            document.getElementById('not-logged-in').style.display = 'block';
            document.getElementById('logged-in').style.display = 'none';
        }

        // 顯示檔案資訊
        function displayProfile() {
            try {
                console.log('🎨 開始顯示 Profile...');
                
                // 隱藏 loading，立即顯示 logged-in 區域（即使後續有錯誤也要顯示）
                document.getElementById('loading-state').style.display = 'none';
                document.getElementById('logged-in').style.display = 'block';
                document.getElementById('not-logged-in').style.display = 'none';
                console.log('✅ 已切換顯示區域');
                
                // 檢查 MBTI_TYPES 是否存在
                if (!GameMBTI.MBTI_TYPES) {
                    console.error('❌ GameMBTI.MBTI_TYPES 不存在！');
                    throw new Error('MBTI_TYPES 未定義');
                }
                
                // 檢查使用者的 MBTI 類型
                console.log('檢查 MBTI 類型:', currentUser.mbti_type);
                const mbtiInfo = GameMBTI.MBTI_TYPES[currentUser.mbti_type];
                
                if (!mbtiInfo) {
                    console.error('❌ 找不到 MBTI 類型:', currentUser.mbti_type);
                    console.log('可用的 MBTI 類型:', Object.keys(GameMBTI.MBTI_TYPES));
                    // 使用預設值繼續
                    mbtiInfo = { name: currentUser.mbti_type, color: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)' };
                }
                console.log('✅ MBTI 資訊:', mbtiInfo);
                
                // 設置背景顏色
                const gradientElement = document.getElementById('profile-gradient');
                if (gradientElement) {
                    gradientElement.style.background = mbtiInfo.color;
                    console.log('✅ 已設置背景顏色');
                }
                
                // 基本資訊
                const usernameElement = document.getElementById('profile-username');
                if (usernameElement) {
                    usernameElement.textContent = currentUser.username || '未命名';
                    console.log('✅ 已設置使用者名稱:', currentUser.username);
                }
                
                const mbtiElement = document.getElementById('profile-mbti');
                if (mbtiElement) {
                    mbtiElement.textContent = currentUser.mbti_type || 'INTJ';
                    console.log('✅ 已設置 MBTI 類型');
                }
                
                const mbtiNameElement = document.getElementById('profile-mbti-name');
                if (mbtiNameElement) {
                    mbtiNameElement.textContent = mbtiInfo.name || '';
                    console.log('✅ 已設置 MBTI 名稱');
                }
                
                // 加入時間
                if (currentUser.created_at) {
                    const createdAtElement = document.getElementById('profile-created-at');
                    if (createdAtElement) {
                        createdAtElement.textContent = '加入於 ' + GameMBTI.formatDate(currentUser.created_at);
                        console.log('✅ 已設置加入時間');
                    }
                }
                
                // 統計數據
                const likedCount = currentUser.liked_games ? currentUser.liked_games.length : 0;
                const dislikedCount = currentUser.disliked_games ? currentUser.disliked_games.length : 0;
                const wishlistCount = currentUser.wishlist ? currentUser.wishlist.length : 0;
                const totalEvaluated = likedCount + dislikedCount; // 只計算已評價（喜歡 + 不喜歡），不含待玩清單
                const sameTypeCount = allUsers.filter(u => u.mbti_type === currentUser.mbti_type && u.id !== currentUser.id).length;
                
                console.log('📊 統計數據:', { likedCount, dislikedCount, wishlistCount, totalEvaluated, sameTypeCount });
                
                // 計算資料庫總遊戲數（從所有使用者的遊戲中統計唯一遊戲）
                const allGamesSet = new Set();
                allUsers.forEach(user => {
                    if (user.liked_games) user.liked_games.forEach(game => allGamesSet.add(game));
                    if (user.disliked_games) user.disliked_games.forEach(game => allGamesSet.add(game));
                    if (user.wishlist) user.wishlist.forEach(game => allGamesSet.add(game));
                });
                const totalGamesInDB = allGamesSet.size;
                console.log('📦 資料庫總遊戲數:', totalGamesInDB);
                
                // 更新已評價遊戲數（分數形式）
                const likedCountElement = document.getElementById('profile-liked-count');
                if (likedCountElement) {
                    likedCountElement.textContent = `${totalEvaluated} / ${totalGamesInDB}`;
                }
                
                // 更新同類型玩家數
                const sameTypeCountElement = document.getElementById('profile-same-type-count');
                if (sameTypeCountElement) {
                    sameTypeCountElement.textContent = sameTypeCount;
                }
                
                // 計算同類型重疊度
                calculateAndDisplayOverlap();
                
                // 顯示社群連結
                displaySocialLinks();
                
                console.log('✅ displayProfile() 完成');
                
            } catch (error) {
                console.error('❌ displayProfile() 錯誤:', error);
                console.error('錯誤堆疊:', error.stack);
                // 即使有錯誤也要顯示區域
                document.getElementById('loading-state').style.display = 'none';
                document.getElementById('logged-in').style.display = 'block';
                document.getElementById('not-logged-in').style.display = 'none';
                // 顯示錯誤訊息給使用者
                alert('⚠️ 顯示檔案時發生部分錯誤\n\n錯誤: ' + error.message + '\n\n頁面可能不完整，請重新整理或聯絡管理員');
            }
        }

        // 計算並顯示同類型重疊度
        function calculateAndDisplayOverlap() {
            try {
                const userLikedGames = currentUser.liked_games || [];
                
                if (userLikedGames.length === 0) {
                    // 沒有喜歡的遊戲
                    document.getElementById('overlap-percentage').textContent = '0%';
                    document.getElementById('overlap-bar').style.width = '0%';
                    document.getElementById('overlap-description').textContent = '尚未評價足夠的遊戲';
                    document.getElementById('tendency-badge').textContent = '🌱 新手玩家';
                    document.getElementById('tendency-badge').style.background = 'linear-gradient(135deg, #94a3b8 0%, #64748b 100%)';
                    document.getElementById('tendency-badge').style.color = 'white';
                    return;
                }
                
                // 取得同類型玩家（排除自己）
                const sameTypeUsers = allUsers.filter(u => 
                    u.mbti_type === currentUser.mbti_type && 
                    u.id !== currentUser.id
                );
                
                if (sameTypeUsers.length === 0) {
                    document.getElementById('overlap-percentage').textContent = 'N/A';
                    document.getElementById('overlap-bar').style.width = '0%';
                    document.getElementById('overlap-description').textContent = '目前沒有其他同類型玩家';
                    document.getElementById('tendency-badge').textContent = '🦄 唯一玩家';
                    document.getElementById('tendency-badge').style.background = 'linear-gradient(135deg, #a78bfa 0%, #8b5cf6 100%)';
                    document.getElementById('tendency-badge').style.color = 'white';
                    return;
                }
                
                // 計算同類型玩家的熱門遊戲（取 Top 20 喜歡 + Top 20 不喜歡）
                const sameTypePopularGames = GameMBTI.getPopularGamesByMBTI(allUsers, currentUser.mbti_type);
                const sameTypeDislikedGames = GameMBTI.getDislikedGamesByMBTI(allUsers, currentUser.mbti_type);
                
                const sameTypeTop20Liked = sameTypePopularGames.slice(0, 20).map(g => g.game);
                const sameTypeTop20Disliked = sameTypeDislikedGames.slice(0, 20).map(g => g.game);
                
                const topLikedCount = sameTypeTop20Liked.length;
                const topDislikedCount = sameTypeTop20Disliked.length;
                const totalTopGames = topLikedCount + topDislikedCount;
                
                if (totalTopGames === 0) {
                    document.getElementById('overlap-percentage').textContent = 'N/A';
                    document.getElementById('overlap-bar').style.width = '0%';
                    document.getElementById('overlap-description').textContent = '同類型玩家尚未評價足夠遊戲';
                    document.getElementById('tendency-badge').textContent = '🌱 資料不足';
                    document.getElementById('tendency-badge').style.background = 'linear-gradient(135deg, #94a3b8 0%, #64748b 100%)';
                    document.getElementById('tendency-badge').style.color = 'white';
                    return;
                }
                
                // 取得使用者的不喜歡清單
                const userDislikedGames = currentUser.disliked_games || [];
                
                // 計算雙向重疊
                // 1. 你喜歡 且 同類型也喜歡的遊戲
                const likedOverlap = userLikedGames.filter(game => 
                    sameTypeTop20Liked.includes(game)
                ).length;
                
                // 2. 你不喜歡 且 同類型也不喜歡的遊戲
                const dislikedOverlap = userDislikedGames.filter(game => 
                    sameTypeTop20Disliked.includes(game)
                ).length;
                
                // 總重疊數 = 喜歡的重疊 + 不喜歡的重疊
                const overlapCount = likedOverlap + dislikedOverlap;
                
                // 計算百分比
                const overlapPercentage = Math.round((overlapCount / totalTopGames) * 100);
                
                console.log('📊 重疊度計算:', {
                    userLikedCount: userLikedGames.length,
                    userDislikedCount: userDislikedGames.length,
                    topLikedCount: topLikedCount,
                    topDislikedCount: topDislikedCount,
                    totalTopGames: totalTopGames,
                    likedOverlap: likedOverlap,
                    dislikedOverlap: dislikedOverlap,
                    overlapCount: overlapCount,
                    overlapPercentage: overlapPercentage,
                    message: '雙向重疊：喜歡的重疊 + 不喜歡的重疊'
                });
                
                // 更新顯示
                document.getElementById('overlap-percentage').textContent = overlapPercentage + '%';
                document.getElementById('overlap-bar').style.width = overlapPercentage + '%';
                
                // 設定描述文字和趨向性徽章
                let description = '';
                let badgeText = '';
                let badgeColor = '';
                
                if (overlapPercentage >= 80) {
                    description = `品味重疊 ${overlapCount}/${totalTopGames} 款（😍${likedOverlap} + 😞${dislikedOverlap}）`;
                    badgeText = '🎯 主流型玩家';
                    badgeColor = 'linear-gradient(135deg, #10b981 0%, #059669 100%)';
                } else if (overlapPercentage >= 60) {
                    description = `品味重疊 ${overlapCount}/${totalTopGames} 款（😍${likedOverlap} + 😞${dislikedOverlap}）`;
                    badgeText = '✨ 典型型玩家';
                    badgeColor = 'linear-gradient(135deg, #3b82f6 0%, #2563eb 100%)';
                } else if (overlapPercentage >= 40) {
                    description = `品味重疊 ${overlapCount}/${totalTopGames} 款（😍${likedOverlap} + 😞${dislikedOverlap}）`;
                    badgeText = '🎨 獨特型玩家';
                    badgeColor = 'linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%)';
                } else if (overlapPercentage >= 20) {
                    description = `品味重疊 ${overlapCount}/${totalTopGames} 款（😍${likedOverlap} + 😞${dislikedOverlap}）`;
                    badgeText = '🌟 小眾型玩家';
                    badgeColor = 'linear-gradient(135deg, #f59e0b 0%, #d97706 100%)';
                } else {
                    description = `品味重疊 ${overlapCount}/${totalTopGames} 款（😍${likedOverlap} + 😞${dislikedOverlap}）`;
                    badgeText = '🚀 探索型玩家';
                    badgeColor = 'linear-gradient(135deg, #ef4444 0%, #dc2626 100%)';
                }
                
                document.getElementById('overlap-description').textContent = description;
                document.getElementById('tendency-badge').textContent = badgeText;
                document.getElementById('tendency-badge').style.background = badgeColor;
                document.getElementById('tendency-badge').style.color = 'white';
                
                console.log('📊 重疊度計算完成:', {
                    overlapCount,
                    totalTopGames: totalTopGames,
                    likedOverlap: likedOverlap,
                    dislikedOverlap: dislikedOverlap,
                    percentage: overlapPercentage,
                    type: badgeText
                });
                
            } catch (error) {
                console.error('計算重疊度失敗:', error);
                document.getElementById('overlap-percentage').textContent = 'Error';
                document.getElementById('overlap-description').textContent = '計算失敗';
            }
        }

        // 顯示使用者統計資料（XP、等級、徽章）
        async function displayUserStats() {
            try {
                // 載入使用者統計資料
                const stats = await GameMBTI.getUserStats(currentUser.id);
                
                // 更新等級徽章
                document.getElementById('profile-level-badge').textContent = `Lv. ${stats.level}`;
                
                // 計算當前等級和下一等級的 XP
                const currentLevelXP = GameMBTI.getLevelXP(stats.level);
                const nextLevelXP = GameMBTI.getLevelXP(stats.level + 1);
                const xpInCurrentLevel = stats.total_xp - currentLevelXP;
                const xpNeededForNextLevel = nextLevelXP - currentLevelXP;
                const progressPercent = (xpInCurrentLevel / xpNeededForNextLevel) * 100;
                
                // 更新 XP 文字和進度條
                document.getElementById('profile-xp-text').textContent = 
                    `${xpInCurrentLevel} / ${xpNeededForNextLevel} XP`;
                document.getElementById('profile-xp-bar').style.width = `${progressPercent}%`;
                
                // 載入並顯示徽章
                await displayAchievements(stats);
                
            } catch (error) {
                console.error('Error loading user stats:', error);
                // 如果沒有統計資料，顯示預設值
                document.getElementById('profile-level-badge').textContent = 'Lv. 1';
                document.getElementById('profile-xp-text').textContent = '0 / 100 XP';
                document.getElementById('profile-xp-bar').style.width = '0%';
            }
        }

        // 顯示成就徽章
        async function displayAchievements(stats) {
            const container = document.getElementById('achievements-wall');
            
            try {
                // 載入所有成就定義
                const allAchievements = await GameMBTI.getAllAchievements();
                const unlockedIds = stats.unlocked_badges || [];
                
                if (allAchievements.length === 0) {
                    container.innerHTML = '<p style="color: var(--text-light);">尚無成就資料</p>';
                    return;
                }
                
                // 渲染成就徽章
                container.innerHTML = allAchievements.map(achievement => {
                    const isUnlocked = unlockedIds.includes(achievement.id);
                    const opacity = isUnlocked ? '1' : '0.3';
                    const filter = isUnlocked ? 'none' : 'grayscale(100%)';
                    
                    return `
                        <div class="achievement-card" style="opacity: ${opacity}; filter: ${filter};">
                            <div class="achievement-icon" style="font-size: 3rem; margin-bottom: 0.5rem;">
                                ${achievement.icon}
                            </div>
                            <h4 style="margin: 0 0 0.25rem 0; font-size: 1rem;">${achievement.name_zh}</h4>
                            <p style="margin: 0; font-size: 0.85rem; color: var(--text-light);">${achievement.description}</p>
                            ${isUnlocked ? '<div style="margin-top: 0.5rem; color: var(--primary-color); font-weight: 600;">✓ 已解鎖</div>' : '<div style="margin-top: 0.5rem; color: var(--text-light); font-size: 0.85rem;">🔒 尚未解鎖</div>'}
                        </div>
                    `;
                }).join('');
                
            } catch (error) {
                console.error('Error loading achievements:', error);
                container.innerHTML = '<p style="color: var(--text-light);">載入成就時發生錯誤</p>';
            }
        }

        // 顯示遊戲列表
        function displayGames() {
            try {
                console.log('🎮 開始顯示遊戲列表...');
                
                const MAX_DISPLAY = 5; // 🎯 最多顯示 5 個
                
                // 喜歡的遊戲
                const likedContainer = document.getElementById('profile-liked-games');
                const likedMoreContainer = document.getElementById('profile-liked-more');
                if (likedContainer && likedMoreContainer) {
                    if (!currentUser.liked_games || currentUser.liked_games.length === 0) {
                        likedContainer.innerHTML = '<div class="empty-state"><p>尚未新增</p></div>';
                        likedMoreContainer.innerHTML = '';
                    } else {
                        const totalLiked = currentUser.liked_games.length;
                        const displayLiked = currentUser.liked_games.slice(0, MAX_DISPLAY);
                        const hasMore = totalLiked > MAX_DISPLAY;
                        
                        likedContainer.innerHTML = '<div class="game-tags-container">' + displayLiked.map(game => `
                            <div class="game-tag">${game}</div>
                        `).join('') + '</div>';
                        
                        likedMoreContainer.innerHTML = hasMore ? `
                            <a href="games-list.html?type=liked" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.5rem 1rem;">
                                查看完整清單 (${totalLiked} 款) →
                            </a>
                        ` : '';
                    }
                    console.log('✅ 已顯示喜歡的遊戲:', currentUser.liked_games?.length || 0);
                }
                
                // 不喜歡的遊戲
                const dislikedContainer = document.getElementById('profile-disliked-games');
                const dislikedMoreContainer = document.getElementById('profile-disliked-more');
                if (dislikedContainer && dislikedMoreContainer) {
                    if (!currentUser.disliked_games || currentUser.disliked_games.length === 0) {
                        dislikedContainer.innerHTML = '<div class="empty-state"><p>尚未新增</p></div>';
                        dislikedMoreContainer.innerHTML = '';
                    } else {
                        const totalDisliked = currentUser.disliked_games.length;
                        const displayDisliked = currentUser.disliked_games.slice(0, MAX_DISPLAY);
                        const hasMore = totalDisliked > MAX_DISPLAY;
                        
                        dislikedContainer.innerHTML = '<div class="game-tags-container">' + displayDisliked.map(game => `
                            <div class="game-tag disliked">${game}</div>
                        `).join('') + '</div>';
                        
                        dislikedMoreContainer.innerHTML = hasMore ? `
                            <a href="games-list.html?type=disliked" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.5rem 1rem;">
                                查看完整清單 (${totalDisliked} 款) →
                            </a>
                        ` : '';
                    }
                    console.log('✅ 已顯示不喜歡的遊戲:', currentUser.disliked_games?.length || 0);
                }
                
                // 願望清單
                const wishlistContainer = document.getElementById('profile-wishlist');
                const wishlistMoreContainer = document.getElementById('profile-wishlist-more');
                if (wishlistContainer && wishlistMoreContainer) {
                    if (!currentUser.wishlist || currentUser.wishlist.length === 0) {
                        wishlistContainer.innerHTML = '<div class="empty-state"><p>尚未新增<br><small style="color: var(--text-light);">前往<a href="recommend.html" style="color: var(--primary-color);">每日推薦</a>標記「沒玩過」</small></p></div>';
                        wishlistMoreContainer.innerHTML = '';
                    } else {
                        const totalWishlist = currentUser.wishlist.length;
                        const displayWishlist = currentUser.wishlist.slice(0, MAX_DISPLAY);
                        const hasMore = totalWishlist > MAX_DISPLAY;
                        
                        wishlistContainer.innerHTML = '<div class="game-tags-container">' + displayWishlist.map(game => `
                            <div class="game-tag" style="background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);">${game}</div>
                        `).join('') + '</div>';
                        
                        wishlistMoreContainer.innerHTML = hasMore ? `
                            <a href="games-list.html?type=wishlist" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.5rem 1rem;">
                                查看完整清單 (${totalWishlist} 款) →
                            </a>
                        ` : '';
                    }
                    console.log('✅ 已顯示願望清單:', currentUser.wishlist?.length || 0);
                }
                
                console.log('✅ displayGames() 完成');
                
            } catch (error) {
                console.error('❌ displayGames() 錯誤:', error);
                console.error('錯誤堆疊:', error.stack);
            }
        }

        // 顯示推薦遊戲
        async function displayRecommendations() {
            try {
                console.log('🎯 開始顯示推薦...');
                
                const container = document.getElementById('recommendations');
                if (!container) {
                    console.error('❌ 找不到 recommendations 容器');
                    return;
                }
                
                const popularGames = GameMBTI.getPopularGamesByMBTI(allUsers, currentUser.mbti_type);
                
                // 🎯 過濾掉使用者已經喜歡、不喜歡、或在願望清單中的遊戲
                const userLikedGames = currentUser.liked_games || [];
                const userDislikedGames = currentUser.disliked_games || [];
                const userWishlist = currentUser.wishlist || [];
                const recommendations = popularGames
                    .filter(item => 
                        !userLikedGames.includes(item.game) && 
                        !userDislikedGames.includes(item.game) &&
                        !userWishlist.includes(item.game)
                    )
                    .slice(0, 10);
                
                if (recommendations.length === 0) {
                    container.innerHTML = '<p style="color: var(--text-light);">目前沒有新的推薦，請稍後再來看看！</p>';
                    console.log('⚠️ 沒有推薦遊戲');
                    return;
                }
                
                // 簡化版本：不查詢投票記錄，直接顯示按鈕
                // const userVotes = await getUserVotes(); // 移除這行避免卡住
                
                container.innerHTML = recommendations.map(item => {
                    // const vote = userVotes[item.game]; // 移除
                    const isInWishlist = currentUser.wishlist && currentUser.wishlist.includes(item.game);
                    return `
                        <div style="display: flex; align-items: center; gap: 0.5rem; background: var(--bg-color); padding: 0.75rem; border-radius: 0.5rem; margin-bottom: 0.5rem;">
                            <div style="flex: 1;">
                                <strong>${item.game}</strong>
                                <span style="opacity: 0.7; font-size: 0.9rem; margin-left: 0.5rem;">
                                    ❤️ ${item.count} 位同類型玩家推薦
                                </span>
                            </div>
                            <div style="display: flex; gap: 0.25rem;">
                                <button 
                                    onclick="voteGame('${item.game.replace(/'/g, "\\'")}', 'agree')"
                                    class="btn btn-secondary"
                                    style="padding: 0.5rem 1rem; font-size: 0.9rem;"
                                    title="喜歡"
                                >
                                    👍
                                </button>
                                <button 
                                    onclick="voteGame('${item.game.replace(/'/g, "\\'")}', 'disagree')"
                                    class="btn btn-secondary"
                                    style="padding: 0.5rem 1rem; font-size: 0.9rem;"
                                    title="不喜歡"
                                >
                                    👎
                                </button>
                                <button 
                                    onclick="addToWishlist('${item.game.replace(/'/g, "\\'")}')"
                                    class="btn ${isInWishlist ? 'btn-primary' : 'btn-secondary'}"
                                    style="padding: 0.5rem 1rem; font-size: 0.9rem;"
                                    ${isInWishlist ? 'disabled' : ''}
                                    title="待玩清單"
                                >
                                    ${isInWishlist ? '✓' : '❓'}
                                </button>
                            </div>
                        </div>
                    `;
                }).join('');
                
                console.log('✅ 已顯示推薦遊戲:', recommendations.length);
                
            } catch (error) {
                console.error('❌ displayRecommendations() 錯誤:', error);
                console.error('錯誤堆疊:', error.stack);
                const container = document.getElementById('recommendations');
                if (container) {
                    container.innerHTML = '<p style="color: var(--text-light);">載入推薦時發生錯誤</p>';
                }
            }
        }

        // 獲取使用者投票記錄
        async function getUserVotes() {
            try {
                const response = await fetch(`tables/game_votes?limit=1000`);
                const data = await response.json();
                const votes = {};
                
                if (data.data) {
                    data.data
                        .filter(v => v.user_id === currentUser.id)
                        .forEach(v => {
                            votes[v.game_name] = v.vote_type;
                        });
                }
                
                return votes;
            } catch (error) {
                console.error('Error fetching votes:', error);
                return {};
            }
        }

        // 投票功能（簡化版）
        async function voteGame(gameName, voteType) {
            try {
                // 更新使用者清單
                if (voteType === 'agree') {
                    const likedGames = currentUser.liked_games || [];
                    if (likedGames.includes(gameName)) {
                        console.log('✅ 遊戲已在喜歡清單中');
                        return;
                    }
                    likedGames.push(gameName);
                    await GameMBTI.updateUser(currentUser.id, { liked_games: likedGames });
                    currentUser.liked_games = likedGames;
                } else if (voteType === 'disagree') {
                    const dislikedGames = currentUser.disliked_games || [];
                    if (dislikedGames.includes(gameName)) {
                        console.log('✅ 遊戲已在不喜歡清單中');
                        return;
                    }
                    dislikedGames.push(gameName);
                    await GameMBTI.updateUser(currentUser.id, { disliked_games: dislikedGames });
                    currentUser.disliked_games = dislikedGames;
                }
                
                // 更新 localStorage
                GameMBTI.setCurrentUser(currentUser);
                
                // 🎯 背景執行：增加 XP（不等待）
                const xpAmount = 10;
                GameMBTI.addXP(currentUser.id, xpAmount, voteType === 'agree' ? '喜歡遊戲' : '不喜歡遊戲').catch(err => console.error('XP 更新失敗:', err));
                
                // 🎯 顯示 XP 動畫（不用 alert）
                const recommendContainer = document.getElementById('recommendations');
                if (recommendContainer) {
                    GameMBTI.showXPAnimation(xpAmount, recommendContainer);
                }
                
                // 🎯 立即更新 UI（不等待 API）
                displayGames();
                displayRecommendations();
                
                // 🎯 背景更新統計（不等待）
                displayUserStats().catch(err => console.error('統計更新失敗:', err));
                
                console.log(`✅ ${voteType === 'agree' ? '已加入喜歡清單' : '已加入不喜歡清單'}！+${xpAmount} XP`);
                
            } catch (error) {
                console.error('投票失敗:', error);
                // 只在真正失敗時才顯示錯誤（用 console 而非 alert）
                console.error('❌ 操作失敗，請稍後再試');
            }
        }
        
        // 加入願望清單（簡化版，移除 alert）
        async function addToWishlist(gameName) {
            try {
                const wishlist = currentUser.wishlist || [];
                if (wishlist.includes(gameName)) {
                    console.log('✅ 遊戲已在願望清單中');
                    return;
                }
                
                wishlist.push(gameName);
                await GameMBTI.updateUser(currentUser.id, { wishlist: wishlist });
                currentUser.wishlist = wishlist;
                GameMBTI.setCurrentUser(currentUser);
                
                // 🎯 背景執行：增加 XP（不等待）
                const xpAmount = 5;
                GameMBTI.addXP(currentUser.id, xpAmount, '加入願望清單').catch(err => console.error('XP 更新失敗:', err));
                
                // 🎯 顯示 XP 動畫（不用 alert）
                const recommendContainer = document.getElementById('recommendations');
                if (recommendContainer) {
                    GameMBTI.showXPAnimation(xpAmount, recommendContainer);
                }
                
                // 🎯 立即更新 UI（按鈕會自動變成 ✓ 並 disabled）
                displayGames();
                displayRecommendations();
                
                // 🎯 背景更新統計（不等待）
                displayUserStats().catch(err => console.error('統計更新失敗:', err));
                
                console.log('✅ 已加入願望清單！+' + xpAmount + ' XP');
                
            } catch (error) {
                console.error('加入願望清單失敗:', error);
                // 只在真正失敗時才顯示錯誤（用 console 而非 alert）
                console.error('❌ 操作失敗，請稍後再試');
            }
        }

        // 顯示同類型玩家
        // 計算兩個使用者之間的相似度
        function calculateSimilarity(user1, user2) {
            const liked1 = new Set(user1.liked_games || []);
            const liked2 = new Set(user2.liked_games || []);
            const disliked1 = new Set(user1.disliked_games || []);
            const disliked2 = new Set(user2.disliked_games || []);
            
            // 計算四種交集
            const bothLike = [...liked1].filter(g => liked2.has(g)).length;
            const bothDislike = [...disliked1].filter(g => disliked2.has(g)).length;
            const disagree1 = [...liked1].filter(g => disliked2.has(g)).length; // user1喜歡但user2不喜歡
            const disagree2 = [...liked2].filter(g => disliked1.has(g)).length; // user2喜歡但user1不喜歡
            
            // 相似度 = (共同喜歡 + 共同不喜歡) - (意見相反)
            const agreement = bothLike + bothDislike;
            const disagreement = disagree1 + disagree2;
            const similarity = agreement - disagreement;
            
            return {
                similarity,
                agreement,
                disagreement,
                bothLike,
                bothDislike
            };
        }
        
        function displaySimilarAndDifferentUsers() {
            // 計算所有使用者與當前使用者的相似度
            const otherUsers = allUsers.filter(u => u.id !== currentUser.id);
            
            const usersWithSimilarity = otherUsers.map(user => {
                const simData = calculateSimilarity(currentUser, user);
                return {
                    ...user,
                    ...simData
                };
            });
            
            // 排序：相似度高的在前
            const sortedBySimilarity = [...usersWithSimilarity].sort((a, b) => b.similarity - a.similarity);
            
            // 取最相似的 5 位
            const mostSimilar = sortedBySimilarity.slice(0, 5);
            
            // 取最不相似的 5 位（相似度最低的）
            const mostDifferent = sortedBySimilarity.slice(-5).reverse();
            
            // 顯示最相似玩家
            displayUserCards('most-similar-users', mostSimilar, '相似');
            
            // 顯示最不相似玩家
            displayUserCards('most-different-users', mostDifferent, '不相似');
        }
        
        function displayUserCards(containerId, users, type) {
            const container = document.getElementById(containerId);
            
            if (!users || users.length === 0) {
                container.innerHTML = '<div class="empty-state"><p>目前沒有其他玩家</p></div>';
                return;
            }
            
            container.innerHTML = users.map(user => {
                const isSimilar = type === '相似';
                const color = isSimilar ? 'var(--primary-color)' : 'var(--accent-color)';
                const emoji = isSimilar ? '💚' : '🎨';
                
                return `
                    <div 
                        style="
                            background: var(--bg-color); 
                            padding: 1rem; 
                            border-radius: 0.5rem; 
                            text-align: center;
                            cursor: pointer;
                            transition: all 0.3s ease;
                            border: 2px solid transparent;
                        "
                        onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.15)'; this.style.borderColor='${color}';"
                        onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'; this.style.borderColor='transparent';"
                        onclick="openPlayerProfile('${user.id}')"
                    >
                        <div style="font-size: 2rem; margin-bottom: 0.5rem;">
                            ${user.avatar_url ? `<img src="${user.avatar_url}" style="width:60px;height:60px;border-radius:50%;object-fit:cover;">` : '👤'}
                        </div>
                        <div style="font-weight: 600; margin-bottom: 0.25rem;">${user.username}</div>
                        <div style="font-size: 0.8rem; color: var(--text-light); margin-bottom: 0.5rem;">
                            ${user.mbti_type || '未設定'}
                        </div>
                        <div style="font-size: 0.75rem; color: ${color}; font-weight: 600; margin-bottom: 0.5rem;">
                            ${emoji} 相似度: ${user.similarity >= 0 ? '+' : ''}${user.similarity}
                        </div>
                        <div style="font-size: 0.7rem; color: var(--text-light);">
                            共識 ${user.agreement} | 分歧 ${user.disagreement}
                        </div>
                    </div>
                `;
            }).join('');
        }

        // 刪除檔案
        async function deleteProfile() {
            if (!confirm('確定要刪除你的檔案嗎？此操作無法復原！')) {
                return;
            }
            
            try {
                // 從資料庫刪除
                if (currentUser.id) {
                    await GameMBTI.deleteUser(currentUser.id);
                }
                
                // 清除本地儲存
                GameMBTI.clearCurrentUser();
                
                alert('檔案已刪除！');
                window.location.href = 'index.html';
                
            } catch (error) {
                console.error('Error deleting profile:', error);
                alert('刪除失敗，請稍後再試。');
            }
        }

        // 頁面載入時執行
        if (document.readyState === 'loading') {
            // 文檔還在載入中，等待 DOMContentLoaded
            document.addEventListener('DOMContentLoaded', loadProfile);
        } else {
            // 文檔已經載入完成，立即執行
            console.log('⚡ 文檔已載入，立即執行 loadProfile()');
            loadProfile();
        }
        
        // ===== 玩家檔案預覽功能 =====
        
        // 開啟玩家檔案預覽
        async function openPlayerProfile(userId) {
            try {
                console.log('🔍 開啟玩家檔案:', userId);
                
                // 顯示 Popup
                const overlay = document.getElementById('playerProfileOverlay');
                overlay.style.display = 'flex';
                overlay.style.justifyContent = 'center';
                overlay.style.alignItems = 'center';
                
                // 取得玩家資料
                const playerData = await getUserProfile(userId);
                
                // 顯示玩家資訊
                displayPlayerProfile(playerData);
                
            } catch (error) {
                console.error('載入玩家檔案失敗:', error);
                alert('無法載入玩家檔案，請稍後再試');
                closePlayerProfile();
            }
        }
        
        // 關閉玩家檔案預覽
        function closePlayerProfile(event) {
            // 如果點擊的是 overlay 本身，或者沒有 event（直接呼叫）
            if (!event || event.target.id === 'playerProfileOverlay') {
                const overlay = document.getElementById('playerProfileOverlay');
                overlay.style.display = 'none';
            }
        }
        
        // 取得其他玩家的資料
        async function getUserProfile(userId) {
            try {
                const response = await fetch(`tables/users/${userId}`);
                if (!response.ok) throw new Error('無法取得玩家資料');
                
                const userData = await response.json();
                
                // 回傳結構（已預留 Google OAuth 欄位）
                return {
                    id: userData.id,
                    username: userData.username || '匿名玩家',
                    display_name: userData.display_name || null,  // 預留 Google 真實姓名
                    avatar_url: userData.avatar_url || null,      // 預留 Google 頭像
                    mbti_type: userData.mbti_type || '未設定',
                    level: userData.level || 1,
                    xp: userData.xp || 0,
                    liked_games: userData.liked_games || [],
                    disliked_games: userData.disliked_games || [],
                    wishlist: userData.wishlist || [],
                    social_links: userData.social_links || {}     // 社群連結
                };
            } catch (error) {
                console.error('取得玩家資料失敗:', error);
                throw error;
            }
        }
        
        // 顯示玩家檔案資訊
        function displayPlayerProfile(playerData) {
            // 頭像（預留 Google OAuth）
            const avatarElement = document.getElementById('playerAvatar');
            if (playerData.avatar_url) {
                // 未來有 Google 頭像時會走這裡
                avatarElement.innerHTML = `<img src="${playerData.avatar_url}" class="player-avatar" alt="${playerData.username}">`;
            } else {
                // 現在使用 emoji
                avatarElement.className = 'player-avatar-placeholder';
                avatarElement.textContent = '👤';
            }
            
            // 顯示名稱（優先使用 Google 真實姓名，否則使用平台暱稱）
            const displayName = playerData.display_name || playerData.username;
            document.getElementById('playerDisplayName').textContent = displayName;
            
            // 如果有 Google 真實姓名，則顯示平台暱稱在下方
            const usernameElement = document.getElementById('playerUsername');
            if (playerData.display_name) {
                usernameElement.textContent = `@${playerData.username}`;
                usernameElement.style.display = 'block';
            } else {
                usernameElement.style.display = 'none';
            }
            
            // 統計資訊
            document.getElementById('playerMbti').textContent = playerData.mbti_type;
            document.getElementById('playerLevel').textContent = `Lv.${playerData.level}`;
            document.getElementById('playerXp').textContent = `${playerData.xp} XP`;
            
            // 喜歡的遊戲（顯示前 10 款）
            const likedGamesElement = document.getElementById('playerLikedGames');
            if (playerData.liked_games && playerData.liked_games.length > 0) {
                const gamesToShow = playerData.liked_games.slice(0, 10);
                likedGamesElement.innerHTML = gamesToShow.map(game => 
                    `<div class="player-game-tag">${game}</div>`
                ).join('');
                
                if (playerData.liked_games.length > 10) {
                    likedGamesElement.innerHTML += `<div class="player-game-tag" style="background: var(--text-light);">+${playerData.liked_games.length - 10} 款</div>`;
                }
            } else {
                likedGamesElement.innerHTML = '<div class="player-empty-state">這位玩家還沒有喜歡的遊戲</div>';
            }
            
            // 共同喜好
            const commonGamesElement = document.getElementById('playerCommonGames');
            const commonGames = findCommonGames(currentUser.liked_games || [], playerData.liked_games || []);
            
            if (commonGames.length > 0) {
                commonGamesElement.innerHTML = commonGames.map(game => 
                    `<div class="player-common-game-item">🎲 ${game}</div>`
                ).join('');
            } else {
                commonGamesElement.innerHTML = '<div class="player-empty-state">你們沒有共同喜歡的遊戲</div>';
            }
            
            // 社群連結
            const socialSection = document.getElementById('playerSocialSection');
            const socialLinksElement = document.getElementById('playerSocialLinks');
            const socialLinks = playerData.social_links || {};
            
            // 檢查是否有任何連結
            const hasAnyLink = Object.values(socialLinks).some(link => link && link.trim());
            
            if (hasAnyLink) {
                socialSection.style.display = 'block';
                
                const socialIcons = {
                    discord: '💬',
                    line: '📱',
                    instagram: '📷',
                    facebook: '📘',
                    telegram: '✈️',
                    threads: '🧵'
                };
                
                const socialNames = {
                    discord: 'Discord',
                    line: 'LINE',
                    instagram: 'Instagram',
                    facebook: 'Facebook',
                    telegram: 'Telegram',
                    threads: 'Threads'
                };
                
                let html = '<div style="display: grid; gap: 0.5rem;">';
                
                for (const [platform, value] of Object.entries(socialLinks)) {
                    if (value && value.trim()) {
                        html += `
                            <div style="display: flex; align-items: center; padding: 0.5rem; background: var(--bg-color); border-radius: 0.5rem; font-size: 0.9rem;">
                                <span style="margin-right: 0.5rem;">${socialIcons[platform]}</span>
                                <div>
                                    <span style="color: var(--text-light); margin-right: 0.5rem;">${socialNames[platform]}:</span>
                                    <span style="color: var(--primary-color); word-break: break-all;">${value}</span>
                                </div>
                            </div>
                        `;
                    }
                }
                
                html += '</div>';
                socialLinksElement.innerHTML = html;
            } else {
                socialSection.style.display = 'none';
            }
        }
        
        // 找出共同喜好的遊戲
        function findCommonGames(userGames, playerGames) {
            return userGames.filter(game => playerGames.includes(game));
        }

        // ===== 社群連結管理 =====
        
        // 顯示社群連結
        function displaySocialLinks() {
            const container = document.getElementById('socialLinksDisplay');
            const socialLinks = currentUser.social_links || {};
            
            // 檢查是否有任何連結
            const hasAnyLink = Object.values(socialLinks).some(link => link && link.trim());
            
            if (!hasAnyLink) {
                container.innerHTML = `
                    <div style="text-align: center; padding: 1rem; color: var(--text-light); font-size: 0.9rem;">
                        尚未設定社群連結 · 點擊右上方「✏️ 編輯」按鈕設定
                    </div>
                `;
                return;
            }
            
            // 顯示已設定的連結（緊湊橫向排列）
            const socialIcons = {
                discord: '💬',
                line: '📱',
                instagram: '📷',
                facebook: '📘',
                telegram: '✈️',
                threads: '🧵'
            };
            
            const socialNames = {
                discord: 'Discord',
                line: 'LINE',
                instagram: 'Instagram',
                facebook: 'Facebook',
                telegram: 'Telegram',
                threads: 'Threads'
            };
            
            let html = '<div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">';
            
            for (const [platform, value] of Object.entries(socialLinks)) {
                if (value && value.trim()) {
                    html += `
                        <div style="display: inline-flex; align-items: center; padding: 0.5rem 0.75rem; background: var(--bg-color); border-radius: 2rem; font-size: 0.9rem;">
                            <span style="margin-right: 0.4rem;">${socialIcons[platform]}</span>
                            <span style="color: var(--text-light); margin-right: 0.3rem;">${socialNames[platform]}:</span>
                            <span style="color: var(--primary-color); font-weight: 500;">${value}</span>
                        </div>
                    `;
                }
            }
            
            html += '</div>';
            container.innerHTML = html;
        }
        
        // 切換編輯模式
        function toggleEditSocialLinks() {
            const displayDiv = document.getElementById('socialLinksDisplay');
            const editDiv = document.getElementById('socialLinksEdit');
            const btn = document.getElementById('editSocialLinksBtn');
            
            if (editDiv.style.display === 'none') {
                // 進入編輯模式
                displayDiv.style.display = 'none';
                editDiv.style.display = 'block';
                btn.textContent = '👁️ 檢視';
                
                // 填入現有資料
                const socialLinks = currentUser.social_links || {};
                document.getElementById('input-discord').value = socialLinks.discord || '';
                document.getElementById('input-line').value = socialLinks.line || '';
                document.getElementById('input-instagram').value = socialLinks.instagram || '';
                document.getElementById('input-facebook').value = socialLinks.facebook || '';
                document.getElementById('input-telegram').value = socialLinks.telegram || '';
                document.getElementById('input-threads').value = socialLinks.threads || '';
            } else {
                // 回到顯示模式
                displayDiv.style.display = 'block';
                editDiv.style.display = 'none';
                btn.textContent = '✏️ 編輯連結';
            }
        }
        
        // 儲存社群連結
        async function saveSocialLinks() {
            try {
                const socialLinks = {
                    discord: document.getElementById('input-discord').value.trim(),
                    line: document.getElementById('input-line').value.trim(),
                    instagram: document.getElementById('input-instagram').value.trim(),
                    facebook: document.getElementById('input-facebook').value.trim(),
                    telegram: document.getElementById('input-telegram').value.trim(),
                    threads: document.getElementById('input-threads').value.trim()
                };
                
                // 更新到資料庫
                const response = await fetch(`tables/users/${currentUser.id}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ social_links: socialLinks })
                });
                
                if (!response.ok) throw new Error('儲存失敗');
                
                // 更新本地資料
                currentUser.social_links = socialLinks;
                
                // 重新顯示
                displaySocialLinks();
                toggleEditSocialLinks();
                
                alert('✅ 社群連結已儲存！');
                
            } catch (error) {
                console.error('儲存社群連結失敗:', error);
                alert('❌ 儲存失敗，請稍後再試');
            }
        }
        
        // 安全機制：如果 10 秒後還在載入中，顯示錯誤
        setTimeout(() => {
            const loadingState = document.getElementById('loading-state');
            if (loadingState && loadingState.style.display !== 'none') {
                console.error('⚠️ 載入超時！10 秒後仍在載入中');
                loadingState.innerHTML = `
                    <div style="text-align: center; padding: 4rem 2rem;">
                        <div style="font-size: 3rem; margin-bottom: 1rem;">⚠️</div>
                        <h2 style="color: var(--text-color); margin-bottom: 0.5rem;">載入逾時</h2>
                        <p style="color: var(--text-light); margin-bottom: 1rem;">
                            載入時間過長，可能是網路問題或 API 連線失敗
                        </p>
                        <button onclick="location.reload()" class="btn btn-primary" style="margin-right: 0.5rem;">
                            🔄 重新載入
                        </button>
                        <a href="debug-profile.html" class="btn btn-secondary">
                            🔧 檢查問題
                        </a>
                        <div style="margin-top: 1.5rem; padding: 1rem; background: #f8f9fa; border-radius: 0.5rem; text-align: left;">
                            <strong>請開啟瀏覽器主控台（F12）查看詳細資訊</strong>
                            <br>
                            <small style="color: var(--text-light);">
                                查看 Console 分頁，看看卡在哪一步
                            </small>
                        </div>
                    </div>
                `;
            }
        }, 10000);
    </script>

    <!-- 玩家檔案預覽 Popup -->
    <div class="player-profile-overlay" id="playerProfileOverlay" onclick="closePlayerProfile(event)">
        <div class="player-profile-popup" onclick="event.stopPropagation()">
            <!-- Header -->
            <div class="player-profile-header">
                <button class="player-profile-close" onclick="closePlayerProfile()">&times;</button>
                
                <!-- Avatar (預留 Google OAuth 頭像) -->
                <div id="playerAvatar" class="player-avatar-placeholder">👤</div>
                
                <!-- Display Name (預留 Google 真實姓名) -->
                <div id="playerDisplayName" class="player-display-name">載入中...</div>
                <div id="playerUsername" class="player-username"></div>
                
                <!-- Stats -->
                <div class="player-stats">
                    <div class="player-stat-item">
                        <div id="playerMbti" class="player-stat-value">-</div>
                        <div class="player-stat-label">MBTI</div>
                    </div>
                    <div class="player-stat-item">
                        <div id="playerLevel" class="player-stat-value">-</div>
                        <div class="player-stat-label">等級</div>
                    </div>
                    <div class="player-stat-item">
                        <div id="playerXp" class="player-stat-value">-</div>
                        <div class="player-stat-label">XP</div>
                    </div>
                </div>
            </div>
            
            <!-- Body -->
            <div class="player-profile-body">
                <!-- 喜歡的遊戲 -->
                <div class="player-section">
                    <div class="player-section-title">💚 喜歡的遊戲</div>
                    <div id="playerLikedGames" class="player-games-grid">
                        <div class="loading"><div class="spinner"></div></div>
                    </div>
                </div>
                
                <!-- 共同喜好 -->
                <div class="player-section">
                    <div class="player-section-title">🤝 你們都喜歡的遊戲</div>
                    <div id="playerCommonGames" class="player-common-games">
                        <div class="loading"><div class="spinner"></div></div>
                    </div>
                </div>
                
                <!-- 社群連結 -->
                <div class="player-section" id="playerSocialSection" style="display: none;">
                    <div class="player-section-title">📱 聯絡方式</div>
                    <div id="playerSocialLinks"></div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>
