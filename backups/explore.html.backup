<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>玩家數據 - MBTI × 桌遊配對</title>
    <link rel="stylesheet" href="css/styles.css">
    <link rel="stylesheet" href="css/hourglass-simple.css">
</head>
<body>
    <!-- 導覽列 -->
    <nav class="navbar">
        <div class="navbar-container">
            <a href="index.html" class="navbar-logo">
                <span>🎲</span>
                MBTI × 桌遊配對
            </a>
            <ul class="navbar-menu">
                <li><a href="index.html">回到首頁</a></li>
                <li><a href="explore.html" class="active">玩家數據</a></li>
                <li><a href="recommend.html">桌遊探索</a></li>
                <li><a href="leaderboard.html">貢獻排行</a></li>
                <li><a href="profile.html">我的檔案</a></li>
            </ul>
        </div>
    </nav>

    <!-- 主要內容 -->
    <div class="container">
        <div class="page-header">
            <h1 class="page-title">玩家數據</h1>
            <p class="page-subtitle">查看各人格類型的桌遊偏好與統計數據</p>
        </div>

        <!-- 總覽統計 -->
        <section style="margin-bottom: 3rem;">
            <h2 style="font-size: 1.8rem; margin-bottom: 1.5rem; color: var(--text-color);">📊 總覽統計</h2>
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-value" id="total-users">-</div>
                    <div class="stat-label">位玩家</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="total-games">-</div>
                    <div class="stat-label">款桌遊</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="avg-liked">-</div>
                    <div class="stat-label">平均喜歡桌遊數</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="most-popular-type">-</div>
                    <div class="stat-label">最多玩家類型</div>
                </div>
            </div>
        </section>

        <!-- MBTI 類型篩選 -->
        <section style="margin-bottom: 3rem;">
            <h2 style="font-size: 1.8rem; margin-bottom: 1.5rem; color: var(--text-color);">🎯 選擇 MBTI 類型</h2>
            <p style="color: var(--text-light); margin-bottom: 1.5rem;">
                點擊任一類型查看該人格的桌遊偏好詳情
            </p>
            <div class="mbti-grid" id="mbti-grid">
                <!-- 透過 JavaScript 動態生成 -->
            </div>
        </section>

        <!-- 類型詳細資訊 -->
        <section id="type-detail" style="display: none; margin-bottom: 3rem;">
            <div style="background: var(--card-bg); padding: 2rem; border-radius: 1rem; box-shadow: var(--shadow-lg);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                    <div>
                        <h2 style="font-size: 2rem; margin-bottom: 0.5rem;" id="selected-type-title">INTJ</h2>
                        <p style="color: var(--text-light); font-size: 1.1rem;" id="selected-type-subtitle">建築師</p>
                        <p style="color: var(--text-light); margin-top: 0.5rem;" id="selected-type-desc">富有想像力和戰略性的思考者，一切皆在計劃之中。</p>
                    </div>
                    <button class="btn btn-secondary" onclick="closeTypeDetail()">✕ 關閉</button>
                </div>

                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
                    <div class="stat-card">
                        <div class="stat-value" id="type-user-count">-</div>
                        <div class="stat-label">位玩家</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="type-liked-count">-</div>
                        <div class="stat-label">喜歡的遊戲總數</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="type-disliked-count">-</div>
                        <div class="stat-label">不喜歡的遊戲總數</div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
                    <!-- 熱門遊戲 -->
                    <div class="game-list">
                        <h3 class="game-list-title"><span style="font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji';">😍</span> 最受歡迎的遊戲</h3>
                        <div id="type-popular-games">
                            <div class="simple-hourglass">
                                <span class="hourglass-icon-simple combined">⏳</span>
                                <span class="hourglass-text-simple">載入中...</span>
                            </div>
                        </div>
                    </div>

                    <!-- 不受歡迎遊戲 -->
                    <div class="game-list">
                        <h3 class="game-list-title"><span style="font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji';">😕</span> 最不受歡迎的遊戲</h3>
                        <div id="type-disliked-games">
                            <div class="simple-hourglass">
                                <span class="hourglass-icon-simple combined">⏳</span>
                                <span class="hourglass-text-simple">載入中...</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 該類型的玩家列表 -->
                <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--border-color);">
                    <h3 style="font-size: 1.3rem; margin-bottom: 1rem;">👥 該類型的玩家</h3>
                    <div id="type-users-list" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem;">
                        <!-- 透過 JavaScript 動態生成 -->
                    </div>
                </div>
            </div>
        </section>

        <!-- 全站遊戲排行 -->
        <section style="margin-bottom: 3rem;">
            <h2 style="font-size: 1.8rem; margin-bottom: 1.5rem; color: var(--text-color);"><span style="font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji';">🏆</span> 全站桌遊排行</h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
                <div class="game-list">
                    <h3 class="game-list-title"><span style="font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji';">😍</span> 最受歡迎</h3>
                    <div id="global-popular-games">
                        <div class="simple-hourglass">
                            <span class="hourglass-icon-simple combined">⏳</span>
                            <span class="hourglass-text-simple">載入中...</span>
                        </div>
                    </div>
                </div>

                <div class="game-list">
                    <h3 class="game-list-title"><span style="font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji';">😕</span> 最不受歡迎</h3>
                    <div id="global-disliked-games">
                        <div class="simple-hourglass">
                            <span class="hourglass-icon-simple combined">⏳</span>
                            <span class="hourglass-text-simple">載入中...</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <!-- 頁尾 -->
    <footer style="text-align: center; padding: 2rem; margin-top: 4rem; color: var(--text-light); border-top: 1px solid var(--border-color);">
        <p>© 2025 MBTI × 桌遊配對</p>
    </footer>

    <script src="js/app.js"></script>
<script src="js/navbar-auth.js"></script>
    <script>
        let allUsers = [];
        let selectedType = null;

        // 載入所有資料
        async function loadAllData() {
            try {
                allUsers = await GameMBTI.getAllUsers();
                displayOverallStats();
                displayMBTIGrid();
                displayGlobalGames();
                
                // 檢查 URL hash
                const hash = window.location.hash.substring(1);
                if (hash && GameMBTI.MBTI_TYPES[hash]) {
                    selectMBTIType(hash);
                }
            } catch (error) {
                console.error('Error loading data:', error);
            }
        }

        // 顯示總覽統計
        function displayOverallStats() {
            const stats = GameMBTI.calculateStats(allUsers);
            
            document.getElementById('total-users').textContent = stats.totalUsers;
            
            // 計算總遊戲數
            const allGames = new Set();
            allUsers.forEach(user => {
                if (user.liked_games) user.liked_games.forEach(g => allGames.add(g));
                if (user.disliked_games) user.disliked_games.forEach(g => allGames.add(g));
            });
            document.getElementById('total-games').textContent = allGames.size;
            
            // 平均喜歡遊戲數
            const totalLikedGames = allUsers.reduce((sum, user) => 
                sum + (user.liked_games ? user.liked_games.length : 0), 0
            );
            const avgLiked = allUsers.length > 0 ? (totalLikedGames / allUsers.length).toFixed(1) : 0;
            document.getElementById('avg-liked').textContent = avgLiked;
            
            // 最多玩家類型
            const mostPopular = Object.entries(stats.mbtiDistribution)
                .sort((a, b) => b[1] - a[1])[0];
            document.getElementById('most-popular-type').textContent = 
                mostPopular ? mostPopular[0] : '-';
        }

        // 顯示 MBTI 網格
        function displayMBTIGrid() {
            const container = document.getElementById('mbti-grid');
            const grouped = GameMBTI.groupUsersByMBTI(allUsers);
            
            container.innerHTML = Object.entries(GameMBTI.MBTI_TYPES).map(([type, info]) => {
                const count = grouped[type].length;
                const isSelected = selectedType === type;
                
                return `
                    <div class="mbti-card ${isSelected ? 'selected' : ''}" 
                         style="--mbti-gradient: ${info.color};" 
                         onclick="selectMBTIType('${type}')">
                        <h3 class="mbti-type">${type}</h3>
                        <p class="mbti-name">${info.name}</p>
                        <p class="mbti-description">${info.description}</p>
                        <div class="mbti-count">
                            👥 ${count} 位玩家
                        </div>
                    </div>
                `;
            }).join('');
        }

        // 選擇 MBTI 類型
        function selectMBTIType(type) {
            selectedType = type;
            window.location.hash = type;
            
            const info = GameMBTI.MBTI_TYPES[type];
            const typeUsers = allUsers.filter(u => u.mbti_type === type);
            
            // 更新標題
            document.getElementById('selected-type-title').textContent = type;
            document.getElementById('selected-type-subtitle').textContent = info.name;
            document.getElementById('selected-type-desc').textContent = info.description;
            
            // 更新統計
            document.getElementById('type-user-count').textContent = typeUsers.length;
            
            const totalLiked = typeUsers.reduce((sum, u) => 
                sum + (u.liked_games ? u.liked_games.length : 0), 0
            );
            document.getElementById('type-liked-count').textContent = totalLiked;
            
            const totalDisliked = typeUsers.reduce((sum, u) => 
                sum + (u.disliked_games ? u.disliked_games.length : 0), 0
            );
            document.getElementById('type-disliked-count').textContent = totalDisliked;
            
            // 顯示熱門遊戲
            const popularGames = GameMBTI.getPopularGamesByMBTI(allUsers, type);
            displayTypeGames('type-popular-games', popularGames, '😍');
            
            const dislikedGames = GameMBTI.getDislikedGamesByMBTI(allUsers, type);
            displayTypeGames('type-disliked-games', dislikedGames, '😕');
            
            // 顯示玩家列表
            displayTypeUsers(typeUsers);
            
            // 顯示詳情區塊
            document.getElementById('type-detail').style.display = 'block';
            document.getElementById('type-detail').scrollIntoView({ behavior: 'smooth' });
            
            // 更新網格選中狀態
            displayMBTIGrid();
        }

        // 關閉類型詳情
        function closeTypeDetail() {
            selectedType = null;
            window.location.hash = '';
            document.getElementById('type-detail').style.display = 'none';
            displayMBTIGrid();
        }

        // 顯示類型遊戲列表
        function displayTypeGames(containerId, games, emoji) {
            const container = document.getElementById(containerId);
            
            if (games.length === 0) {
                container.innerHTML = '<div class="empty-state"><p>尚無資料</p></div>';
                return;
            }
            
            container.innerHTML = games.slice(0, 10).map((item, index) => `
                <div class="game-item">
                    <span class="game-name">${index + 1}. ${item.game}</span>
                    <span class="game-votes">${emoji} ${item.count}</span>
                </div>
            `).join('');
        }

        // 顯示類型玩家列表
        function displayTypeUsers(users) {
            const container = document.getElementById('type-users-list');
            
            if (users.length === 0) {
                container.innerHTML = '<div class="empty-state"><p>尚無玩家</p></div>';
                return;
            }
            
            container.innerHTML = users.map(user => `
                <div 
                    style="
                        background: var(--bg-color); 
                        padding: 1rem; 
                        border-radius: 0.5rem; 
                        text-align: center;
                        cursor: pointer;
                        transition: all 0.3s ease;
                        border: 2px solid transparent;
                    "
                    onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.15)'; this.style.borderColor='var(--primary-color)';"
                    onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'; this.style.borderColor='transparent';"
                    onclick="openPlayerProfile('${user.id}')"
                >
                    <div style="font-size: 2rem; margin-bottom: 0.5rem;">👤</div>
                    <div style="font-weight: 600; margin-bottom: 0.25rem;">${user.username}</div>
                    <div style="font-size: 0.85rem; color: var(--text-light); margin-bottom: 0.5rem;">
                        ${user.liked_games ? user.liked_games.length : 0} 喜歡 / 
                        ${user.disliked_games ? user.disliked_games.length : 0} 不喜歡
                    </div>
                    <div style="font-size: 0.75rem; color: var(--primary-color); font-weight: 500;">
                        點擊查看 →
                    </div>
                </div>
            `).join('');
        }

        // 顯示全站遊戲排行
        function displayGlobalGames() {
            const stats = GameMBTI.calculateStats(allUsers);
            
            const popularContainer = document.getElementById('global-popular-games');
            if (stats.mostPopularGames.length === 0) {
                popularContainer.innerHTML = '<div class="empty-state"><p>尚無資料</p></div>';
            } else {
                popularContainer.innerHTML = stats.mostPopularGames.slice(0, 10).map((item, index) => `
                    <div class="game-item">
                        <span class="game-name">${index + 1}. ${item.game}</span>
                        <span class="game-votes">❤️ ${item.count}</span>
                    </div>
                `).join('');
            }
            
            const dislikedContainer = document.getElementById('global-disliked-games');
            if (stats.mostDislikedGames.length === 0) {
                dislikedContainer.innerHTML = '<div class="empty-state"><p>尚無資料</p></div>';
            } else {
                dislikedContainer.innerHTML = stats.mostDislikedGames.slice(0, 10).map((item, index) => `
                    <div class="game-item">
                        <span class="game-name">${index + 1}. ${item.game}</span>
                        <span class="game-votes">💔 ${item.count}</span>
                    </div>
                `).join('');
            }
        }

        // 頁面載入時執行
        document.addEventListener('DOMContentLoaded', loadAllData);

        // ===== 玩家檔案預覽功能 =====
        
        // 開啟玩家檔案預覽
        async function openPlayerProfile(userId) {
            try {
                console.log('🔍 開啟玩家檔案:', userId);
                
                // 顯示 Popup
                const overlay = document.getElementById('playerProfileOverlay');
                overlay.style.display = 'flex';
                overlay.style.justifyContent = 'center';
                overlay.style.alignItems = 'center';
                
                // 取得玩家資料
                const playerData = await getUserProfile(userId);
                
                // 取得當前用戶（用於計算共同喜好）
                const currentUser = JSON.parse(localStorage.getItem('mbti_game_user') || '{}');
                
                // 顯示玩家資訊
                displayPlayerProfile(playerData, currentUser);
                
            } catch (error) {
                console.error('載入玩家檔案失敗:', error);
                alert('無法載入玩家檔案，請稍後再試');
                closePlayerProfile();
            }
        }
        
        // 關閉玩家檔案預覽
        function closePlayerProfile(event) {
            if (!event || event.target.id === 'playerProfileOverlay') {
                const overlay = document.getElementById('playerProfileOverlay');
                overlay.style.display = 'none';
            }
        }
        
        // 取得其他玩家的資料
        async function getUserProfile(userId) {
            try {
                const response = await fetch(`tables/users/${userId}`);
                if (!response.ok) throw new Error('無法取得玩家資料');
                
                const userData = await response.json();
                
                return {
                    id: userData.id,
                    username: userData.username || '匿名玩家',
                    display_name: userData.display_name || null,
                    avatar_url: userData.avatar_url || null,
                    mbti_type: userData.mbti_type || '未設定',
                    level: userData.level || 1,
                    xp: userData.xp || 0,
                    liked_games: userData.liked_games || [],
                    disliked_games: userData.disliked_games || [],
                    wishlist: userData.wishlist || [],
                    social_links: userData.social_links || {}     // 社群連結
                };
            } catch (error) {
                console.error('取得玩家資料失敗:', error);
                throw error;
            }
        }
        
        // 顯示玩家檔案資訊
        function displayPlayerProfile(playerData, currentUser) {
            // 頭像
            const avatarElement = document.getElementById('playerAvatar');
            if (playerData.avatar_url) {
                avatarElement.innerHTML = `<img src="${playerData.avatar_url}" class="player-avatar" alt="${playerData.username}">`;
            } else {
                avatarElement.className = 'player-avatar-placeholder';
                avatarElement.textContent = '👤';
            }
            
            // 顯示名稱
            const displayName = playerData.display_name || playerData.username;
            document.getElementById('playerDisplayName').textContent = displayName;
            
            const usernameElement = document.getElementById('playerUsername');
            if (playerData.display_name) {
                usernameElement.textContent = `@${playerData.username}`;
                usernameElement.style.display = 'block';
            } else {
                usernameElement.style.display = 'none';
            }
            
            // 統計資訊
            document.getElementById('playerMbti').textContent = playerData.mbti_type;
            document.getElementById('playerLevel').textContent = `Lv.${playerData.level}`;
            document.getElementById('playerXp').textContent = `${playerData.xp} XP`;
            
            // 喜歡的遊戲
            const likedGamesElement = document.getElementById('playerLikedGames');
            if (playerData.liked_games && playerData.liked_games.length > 0) {
                const gamesToShow = playerData.liked_games.slice(0, 10);
                likedGamesElement.innerHTML = gamesToShow.map(game => 
                    `<div class="player-game-tag">${game}</div>`
                ).join('');
                
                if (playerData.liked_games.length > 10) {
                    likedGamesElement.innerHTML += `<div class="player-game-tag" style="background: var(--text-light);">+${playerData.liked_games.length - 10} 款</div>`;
                }
            } else {
                likedGamesElement.innerHTML = '<div class="player-empty-state">這位玩家還沒有喜歡的遊戲</div>';
            }
            
            // 共同喜好
            const commonGamesElement = document.getElementById('playerCommonGames');
            const commonGames = findCommonGames(currentUser.liked_games || [], playerData.liked_games || []);
            
            if (commonGames.length > 0) {
                commonGamesElement.innerHTML = commonGames.map(game => 
                    `<div class="player-common-game-item">🎲 ${game}</div>`
                ).join('');
            } else {
                commonGamesElement.innerHTML = '<div class="player-empty-state">你們沒有共同喜歡的遊戲</div>';
            }
            
            // 社群連結
            const socialSection = document.getElementById('playerSocialSection');
            const socialLinksElement = document.getElementById('playerSocialLinks');
            const socialLinks = playerData.social_links || {};
            
            // 檢查是否有任何連結
            const hasAnyLink = Object.values(socialLinks).some(link => link && link.trim());
            
            if (hasAnyLink) {
                socialSection.style.display = 'block';
                
                const socialIcons = {
                    discord: '💬',
                    line: '📱',
                    instagram: '📷',
                    facebook: '📘',
                    telegram: '✈️',
                    threads: '🧵'
                };
                
                const socialNames = {
                    discord: 'Discord',
                    line: 'LINE',
                    instagram: 'Instagram',
                    facebook: 'Facebook',
                    telegram: 'Telegram',
                    threads: 'Threads'
                };
                
                let html = '<div style="display: grid; gap: 0.5rem;">';
                
                for (const [platform, value] of Object.entries(socialLinks)) {
                    if (value && value.trim()) {
                        html += `
                            <div style="display: flex; align-items: center; padding: 0.5rem; background: var(--bg-color); border-radius: 0.5rem; font-size: 0.9rem;">
                                <span style="margin-right: 0.5rem;">${socialIcons[platform]}</span>
                                <div>
                                    <span style="color: var(--text-light); margin-right: 0.5rem;">${socialNames[platform]}:</span>
                                    <span style="color: var(--primary-color); word-break: break-all;">${value}</span>
                                </div>
                            </div>
                        `;
                    }
                }
                
                html += '</div>';
                socialLinksElement.innerHTML = html;
            } else {
                socialSection.style.display = 'none';
            }
        }
        
        // 找出共同喜好的遊戲
        function findCommonGames(userGames, playerGames) {
            return userGames.filter(game => playerGames.includes(game));
        }
    </script>

    <!-- 玩家檔案預覽 Popup -->
    <div class="player-profile-overlay" id="playerProfileOverlay" onclick="closePlayerProfile(event)">
        <div class="player-profile-popup" onclick="event.stopPropagation()">
            <!-- Header -->
            <div class="player-profile-header">
                <button class="player-profile-close" onclick="closePlayerProfile()">&times;</button>
                
                <div id="playerAvatar" class="player-avatar-placeholder">👤</div>
                
                <div id="playerDisplayName" class="player-display-name">載入中...</div>
                <div id="playerUsername" class="player-username"></div>
                
                <div class="player-stats">
                    <div class="player-stat-item">
                        <div id="playerMbti" class="player-stat-value">-</div>
                        <div class="player-stat-label">MBTI</div>
                    </div>
                    <div class="player-stat-item">
                        <div id="playerLevel" class="player-stat-value">-</div>
                        <div class="player-stat-label">等級</div>
                    </div>
                    <div class="player-stat-item">
                        <div id="playerXp" class="player-stat-value">-</div>
                        <div class="player-stat-label">XP</div>
                    </div>
                </div>
            </div>
            
            <!-- Body -->
            <div class="player-profile-body">
                <div class="player-section">
                    <div class="player-section-title">💚 喜歡的遊戲</div>
                    <div id="playerLikedGames" class="player-games-grid">
                        <div class="loading"><div class="spinner"></div></div>
                    </div>
                </div>
                
                <div class="player-section">
                    <div class="player-section-title">🤝 你們都喜歡的遊戲</div>
                    <div id="playerCommonGames" class="player-common-games">
                        <div class="loading"><div class="spinner"></div></div>
                    </div>
                </div>
                
                <!-- 社群連結 -->
                <div class="player-section" id="playerSocialSection" style="display: none;">
                    <div class="player-section-title">📱 聯絡方式</div>
                    <div id="playerSocialLinks"></div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>
